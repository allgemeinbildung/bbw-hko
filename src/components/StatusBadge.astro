---
interface Props {
  status: string
}
const { status } = Astro.props

const labels: Record<string, string> = {
  eingereicht: 'Eingereicht',
  gesichtet: 'Gesichtet',
  freigegeben: 'Freigegeben',
  revision_noetig: 'Revision nötig',
}
const colors: Record<string, string> = {
  eingereicht: 'bg-blue-100 text-blue-800',
  gesichtet: 'bg-amber-100 text-amber-800',
  freigegeben: 'bg-emerald-100 text-emerald-800',
  revision_noetig: 'bg-red-100 text-red-800',
}
---
<span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${colors[status] ?? 'bg-slate-100 text-slate-600'}`}>
  {labels[status] ?? status}
</span>
