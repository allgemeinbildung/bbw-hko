---
import StatusBadge from './StatusBadge.astro'
import { skTooltip } from '../lib/sk-labels'

interface Props {
  material: Record<string, any>
  showAuthor?: boolean
}
const { material: m, showAuthor = false } = Astro.props

function selbstcheckCount(sc: any): number {
  if (!sc || typeof sc !== 'object') return 0
  if (sc.h !== undefined || sc.kn !== undefined) {
    const hVals = sc.h ? Object.values(sc.h as Record<string, boolean>) : []
    const knVals = sc.kn ? Object.values(sc.kn as Record<string, boolean>) : []
    return [...hVals, ...knVals].filter(Boolean).length
  }
  return Object.values(sc as Record<string, boolean>).filter(Boolean).length
}

const TOTAL_CHECKS = 10
const scCount = selbstcheckCount(m.selbstcheck || {})
---
<article class="lion-bg bg-white border border-slate-200 rounded-lg p-4 flex flex-col">
  <div class="flex items-start justify-between gap-2 mb-2">
    <span class="chip chip-green">Kompetenznachweis</span>
    <div class="flex items-center gap-2">
      {scCount === TOTAL_CHECKS
        ? <span class="text-xs text-emerald-600 font-medium">✓ {TOTAL_CHECKS}/{TOTAL_CHECKS}</span>
        : <span class="text-xs text-amber-600 font-medium">⚠ {TOTAL_CHECKS - scCount} offen</span>
      }
      <StatusBadge status={m.status} />
    </div>
  </div>

  <h3 class="font-semibold text-slate-900 leading-tight mb-1">{m.titel}</h3>

  <div class="text-xs text-slate-500 mb-3">
    {showAuthor && m.profiles?.full_name && <span>{m.profiles.full_name} · </span>}
    {m.lehrdauer} · LJ {m.lehrjahr} · T{m.thema_nr} — {m.thema_titel}
  </div>

  <div class="text-xs text-slate-600 mb-3">
    <span class="font-medium">Sprachmodus:</span> {m.sprachmodus_primaer}
  </div>

  <div class="mb-2">
    <div class="text-xs font-medium text-slate-500 uppercase mb-1">Schlüsselkompetenzen</div>
    <div class="flex flex-wrap gap-1">
      {(m.schluesselkompetenzen || []).length > 0
        ? (m.schluesselkompetenzen as string[]).map((sk: string) => (
            <span class="chip" title={skTooltip(sk)}>{sk}</span>
          ))
        : <span class="text-xs text-slate-400 italic">keine</span>
      }
    </div>
  </div>

  <div class="mb-3">
    <div class="text-xs font-medium text-slate-500 uppercase mb-1">Aspekte</div>
    <div class="flex flex-wrap gap-1">
      {(m.aspekte || []).length > 0
        ? (m.aspekte as string[]).map((a: string) => (
            <span class="chip">{a}</span>
          ))
        : <span class="text-xs text-slate-400 italic">keine</span>
      }
    </div>
  </div>

  <div class="text-xs text-slate-700 pt-2 border-t border-slate-100">
    <div class="font-medium text-slate-500 uppercase text-[0.65rem] mb-0.5">
      Handlungsprodukt ({m.handlungsprodukt_typ})
    </div>
    <div>{m.handlungsprodukt_beschreibung}</div>
  </div>

  {m.kt1_kommentar && m.status === 'revision_noetig' && (
    <div class="mt-3 p-2 bg-red-50 border border-red-200 rounded text-xs text-red-700">
      <span class="font-medium">KT1-Kommentar:</span> {m.kt1_kommentar}
    </div>
  )}

  <div class="text-xs text-slate-400 mt-auto pt-3 border-t border-slate-100">
    {new Date(m.created_at).toLocaleDateString('de-CH')}
  </div>
</article>
