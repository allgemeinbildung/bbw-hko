---
// D7 — Aufklappbares Glossar der HKO-Kernbegriffe.
// Single source: src/data/glossar.json. Single-green Stil (keine neuen Farben).
import glossar from '../data/glossar.json'

interface GlossarEntry {
  begriff: string
  kurz: string
  lang?: string
  kanton_alias?: string
}

interface Props {
  title?: string
  open?: boolean
}

const { title = 'Glossar — die wichtigsten Begriffe', open = false } = Astro.props
const entries = glossar as GlossarEntry[]
---
<details class="glossar" open={open}>
  <summary class="glossar-summary">
    <span class="glossar-summary-label">📖 {title}</span>
    <svg class="glossar-chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M6 8l4 4 4-4" />
    </svg>
  </summary>
  <dl class="glossar-list">
    {entries.map((e) => (
      <div class="glossar-item">
        <dt class="glossar-term">{e.begriff}</dt>
        <dd class="glossar-def">
          <span>{e.kurz}</span>
          {e.lang && <span class="glossar-lang">{e.lang}</span>}
          {e.kanton_alias && (
            <span class="glossar-alias">Kantonsbegriff: {e.kanton_alias}</span>
          )}
        </dd>
      </div>
    ))}
  </dl>
</details>

<style>
  .glossar {
    background: white;
    border: 1px solid #e2e8f0;
    border-top: 3px solid var(--brand);
    border-radius: 0.75rem;
    overflow: hidden;
  }
  .glossar-summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem;
    font-weight: 600;
    color: #0f172a;
    user-select: none;
  }
  .glossar-summary::-webkit-details-marker { display: none; }
  .glossar-summary:hover { color: var(--brand-dark); }
  .glossar-summary-label { font-size: 0.95rem; }
  .glossar-chevron {
    width: 1.1rem;
    height: 1.1rem;
    color: var(--brand);
    flex-shrink: 0;
    transition: transform 0.18s;
  }
  .glossar[open] .glossar-chevron { transform: rotate(180deg); }
  .glossar-list {
    margin: 0;
    padding: 0 1.25rem 1.25rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 768px) {
    .glossar-list { grid-template-columns: 1fr 1fr; column-gap: 1.5rem; }
  }
  .glossar-item {
    border-left: 3px solid var(--brand-tint);
    padding-left: 0.75rem;
  }
  .glossar-term {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--brand-dark);
    margin-bottom: 0.15rem;
  }
  .glossar-def {
    margin: 0;
    font-size: 0.8125rem;
    line-height: 1.5;
    color: #475569;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .glossar-lang { color: #64748b; }
  .glossar-alias {
    font-size: 0.75rem;
    color: #92400e;
    background: #fffbeb;
    border: 1px solid #fde68a;
    border-radius: 0.375rem;
    padding: 0.2rem 0.45rem;
    align-self: flex-start;
  }
</style>
