---
import Einheiten from '../layouts/Einheiten.astro'
import Glossar from '../components/Glossar.astro'

const user = Astro.locals.user
if (!user) return Astro.redirect('/login')

const { data: profile } = await Astro.locals.supabase
  .from('profiles')
  .select('role')
  .eq('id', user.id)
  .single()

const role: 'lp' | 'kt1' | 'gast' =
  profile?.role === 'kt1' ? 'kt1' : profile?.role === 'gast' ? 'gast' : 'lp'
---
<Einheiten title="Glossar" role={role}>
  <div class="max-w-4xl mx-auto">
    <div class="mb-5">
      <h1 class="text-2xl font-semibold">Glossar</h1>
      <p class="text-sm text-slate-500 mt-1">Die wichtigsten Begriffe der ABU Reform 2030 — kurz erklärt.</p>
    </div>
    <Glossar open title="Kernbegriffe" />
  </div>
</Einheiten>
