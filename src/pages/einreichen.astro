---
import LP from '../layouts/LP.astro'
import IntakeForm from '../components/IntakeForm.astro'
import { getAccess, bounceKt1 } from '../lib/auth'

const access = await getAccess(Astro)
if (!access) return Astro.redirect('/login')

const bounce = bounceKt1(Astro, access)
if (bounce) return bounce
if (access.role === 'gast') return Astro.redirect('/situationen?error=' + encodeURIComponent('Material einreichen ist nur für angemeldete Lehrpersonen möglich.'))
---
<LP title="Einreichen">
  <IntakeForm initialData={{ abteilung: access.abteilung ?? '' }} />
</LP>
