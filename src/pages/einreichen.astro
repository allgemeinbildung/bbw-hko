---
import LP from '../layouts/LP.astro'
import IntakeForm from '../components/IntakeForm.astro'

const user = Astro.locals.user
if (!user) return Astro.redirect('/login')

const { data: profile } = await Astro.locals.supabase
  .from('profiles')
  .select('role, abteilung')
  .eq('id', user.id)
  .single()

if (profile?.role === 'kt1') return Astro.redirect('/admin')
if (profile?.role === 'gast') return Astro.redirect('/situationen?error=' + encodeURIComponent('Material einreichen ist nur für angemeldete Lehrpersonen möglich.'))
---
<LP title="Einreichen">
  <IntakeForm initialData={{ abteilung: profile?.abteilung ?? '' }} />
</LP>
