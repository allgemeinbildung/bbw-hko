---
import LP from '../layouts/LP.astro'
import IntakeForm from '../components/IntakeForm.astro'

const user = Astro.locals.user
if (!user) return Astro.redirect('/login')

const { data: profile } = await Astro.locals.supabase
  .from('profiles')
  .select('role')
  .eq('id', user.id)
  .single()

if (profile?.role === 'kt1') return Astro.redirect('/admin')
---
<LP title="Einreichen">
  <IntakeForm />
</LP>
