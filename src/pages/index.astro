---
import Base from '../layouts/Base.astro'
import GuestPrintBlock from '../components/GuestPrintBlock.astro'

const user = Astro.locals.user
if (!user) return Astro.redirect('/welcome')

const { data: profile } = await Astro.locals.supabase
  .from('profiles')
  .select('role')
  .eq('id', user.id)
  .single()

if (profile?.role === 'kt1') return Astro.redirect('/admin')
const isGuest = profile?.role === 'gast'

const allTiles = [
  {
    href: '/einheiten',
    title: 'Katalog Einheiten',
    blurb: 'Komplette Unterrichtseinheit (3 Situationen A/B/C + Kompetenznachweis + Begleitdokument) auswählen, als ZIP-Paket herunterladen und unterrichten.',
    cta: 'Zum Katalog',
  },
  {
    href: '/einreichen',
    title: 'Material einreichen',
    blurb: 'Eigenes Material erfassen, mit nRLP-Taxonomie versehen und KT1 zur Review vorlegen.',
    cta: 'Zum Formular',
    lpOnly: true,
  },
  {
    href: '/jahresplanung',
    title: 'Jahresplanung 1. Lehrjahr',
    blurb: 'Schuljahr 2025/2026 auf einen Blick — 39 Wochen, 3 Themen, alle Lebensbezüge interaktiv.',
    cta: 'Jahr ansehen',
  },
]
// Guests get a read-only hub without the «Material einreichen» tile.
const primaryTiles = isGuest ? allTiles.filter(t => !t.lpOnly) : allTiles
---
<Base title="Hauptplattform">
  {isGuest && <GuestPrintBlock />}
  <div class="min-h-screen flex flex-col">
    <header class="bg-white border-b border-slate-200 sticky top-0 z-20">
      <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between gap-4">
        <a href="/" class="flex items-center gap-3 min-w-0">
          <img src="/logo-bbw-mark.png" alt="BBW Berufsbildungsschule Winterthur" class="logo-black h-14 w-auto shrink-0" />
          <span class="sr-only">BBW Berufsbildungsschule Winterthur</span>
          <span class="hidden md:block pl-3 ml-1 border-l border-slate-200 text-xs uppercase tracking-wider text-slate-500 leading-tight">
            ABU-Materialplattform<br />
            <span class="normal-case tracking-normal text-slate-400">ABU Reform 2030</span>
          </span>
        </a>
        <div class="flex items-center gap-4">
          {!isGuest && (
            <a href="/meine-materialien" class="text-sm text-slate-600 hover:text-slate-900 font-medium">Meine Materialien</a>
          )}
          {isGuest && (
            <span class="text-xs font-medium px-2 py-0.5 rounded border border-amber-300 bg-amber-50 text-amber-700">Gast · nur Lesen</span>
          )}
          <a href="/onboarding/index.html" class="text-sm text-slate-400 hover:text-slate-600" title="Einführung &amp; Rundgang">Rundgang</a>
          <span class="text-sm text-slate-500 hidden sm:block">{isGuest ? 'Gast' : user.email}</span>
          <form method="POST" action="/api/auth/logout">
            <button type="submit" class="text-sm text-slate-500 hover:text-slate-700 underline">{isGuest ? 'Verlassen' : 'Abmelden'}</button>
          </form>
        </div>
      </div>
    </header>

    <main class="flex-1 max-w-7xl mx-auto w-full px-6 py-12 relative">
      <div class="mb-10">
        <h1 class="text-3xl font-semibold text-slate-900 tracking-tight">Willkommen auf der ABU-Materialplattform</h1>
        <p class="text-slate-600 mt-3 max-w-3xl">
          Wähle den passenden Einstieg — du kannst jederzeit über «← Hauptplattform»
          hierher zurückkehren.
        </p>
      </div>

      <!-- Primary: Einheiten + Einreichen + Jahresplanung -->
      <div class="grid gap-6 md:grid-cols-3 mb-8">
        {primaryTiles.map(t => (
          <a href={t.href} class="wappen-tile wappen-tile-primary group">
            <div class="wappen-lion" aria-hidden="true"></div>
            <div class="wappen-content">
              <h2 class="wappen-title">{t.title}</h2>
              <p class="wappen-blurb">{t.blurb}</p>
              <span class="wappen-cta">
                {t.cta}
                <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
                  <path d="M5 10h10M11 5l5 5-5 5" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>

      <!-- Secondary: Situationen (text strip) -->
      <div class="border-t border-slate-100 pt-5">
        <p class="text-xs text-slate-400 uppercase tracking-wider mb-3">Weitere Angebote</p>
        <div class="flex flex-wrap gap-x-6 gap-y-2">
          <a href="/situationen" class="inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-[var(--brand)] transition-colors">
            Katalog Situationen
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5">
              <path d="M5 10h10M11 5l5 5-5 5" />
            </svg>
          </a>
        </div>
      </div>
    </main>

    <footer class="border-t border-slate-200 py-4 px-6 text-center text-xs text-slate-400">
      ABU-Materialplattform · ABU Reform 2030 · BBW
    </footer>
  </div>

<style>
  .wappen-tile {
    position: relative;
    display: block;
    overflow: hidden;
    background: white;
    border: 1px solid #e2e8f0;
    border-top: 3px solid var(--brand);
    border-radius: 0.75rem;
    transition: border-color 0.18s, box-shadow 0.18s, transform 0.18s;
  }
  .wappen-tile-primary {
    padding: 2rem 1.75rem 1.75rem;
    min-height: 260px;
  }
  .wappen-tile-secondary {
    padding: 1.25rem 1.25rem 1rem;
    border-top-width: 2px;
    min-height: 0;
  }
  .wappen-tile:hover {
    border-color: var(--brand);
    box-shadow: 0 10px 24px -12px rgba(14, 110, 58, 0.35);
    transform: translateY(-2px);
  }
  .wappen-lion {
    position: absolute;
    right: -30px;
    top: -10px;
    width: 220px;
    height: 240px;
    background-image: url('/lion-only.svg');
    background-repeat: no-repeat;
    background-position: right center;
    background-size: contain;
    opacity: 0.05;
    color: var(--brand);
    transition: opacity 0.18s;
    pointer-events: none;
  }
  .wappen-tile:hover .wappen-lion {
    opacity: 0.09;
  }
  .wappen-content {
    position: relative;
    z-index: 1;
  }
  .wappen-mark {
    width: 2.75rem;
    height: 2.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--brand);
    border-radius: 0.5rem;
    color: var(--brand);
    font-weight: 700;
    font-size: 1.25rem;
    background: white;
    margin-bottom: 1rem;
  }
  .wappen-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: #0f172a;
    margin-bottom: 0.5rem;
  }
  .wappen-blurb {
    font-size: 0.875rem;
    line-height: 1.55;
    color: #475569;
    margin-bottom: 1.25rem;
  }
  .wappen-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--brand);
  }
  .wappen-tile:hover .wappen-cta,
  .wappen-tile:hover .wappen-cta-sm {
    color: var(--brand-dark);
  }
  .wappen-title-sm {
    font-size: 0.95rem;
    font-weight: 600;
    color: #0f172a;
    margin-bottom: 0.25rem;
  }
  .wappen-blurb-sm {
    font-size: 0.8rem;
    line-height: 1.5;
    color: #64748b;
    margin-bottom: 0.625rem;
  }
  .wappen-cta-sm {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--brand);
  }
</style>
</Base>
