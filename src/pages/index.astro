---
import Base from '../layouts/Base.astro'
import GuestPrintBlock from '../components/GuestPrintBlock.astro'
import { getAccess, bounceKt1 } from '../lib/auth'

const access = await getAccess(Astro)
if (!access) return Astro.redirect('/welcome')

// KT1 lands on /admin unless they opted into the LP-Ansicht preview.
const bounce = bounceKt1(Astro, access)
if (bounce) return bounce

const isGuest = access.role === 'gast'

const allTiles = [
  {
    href: '/einheiten',
    title: 'Katalog Unterrichtseinheiten',
    blurb: 'Komplette Unterrichtseinheit (3 Herausforderungen A/B/C + Kompetenznachweis + Begleitdokument) auswählen, als ZIP-Paket herunterladen und unterrichten.',
    cta: 'Zum Katalog',
  },
  {
    href: '/einreichen',
    title: 'Material einreichen',
    blurb: 'Eigenes Material erfassen, mit nRLP-Taxonomie versehen und KT1 zur Review vorlegen.',
    cta: 'Zum Formular',
    lpOnly: true,
  },
]
// Guests get a read-only hub without the «Material einreichen» tile.
const primaryTiles = isGuest ? allTiles.filter(t => !t.lpOnly) : allTiles
---
<Base title="Hauptplattform">
  {isGuest && <GuestPrintBlock />}
  <div class="min-h-screen flex flex-col">
    <header class="bg-white border-b border-slate-200 sticky top-0 z-20">
      <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between gap-4">
        <a href="/" class="flex items-center gap-3 min-w-0">
          <img src="/logo-bbw-mark.png" alt="BBW Berufsbildungsschule Winterthur" class="logo-black h-14 w-auto shrink-0" />
          <span class="sr-only">BBW Berufsbildungsschule Winterthur</span>
          <span class="hidden md:block pl-3 ml-1 border-l border-slate-200 text-xs uppercase tracking-wider text-slate-500 leading-tight">
            Materialplattform<br />
            <span class="normal-case tracking-normal text-slate-400">ABU Reform 2030</span>
          </span>
        </a>
        <div class="flex items-center gap-4">
          {!isGuest && (
            <a href="/meine-materialien" class="text-sm text-slate-600 hover:text-slate-900 font-medium">Meine Materialien</a>
          )}
          {isGuest && (
            <span class="text-xs font-medium px-2 py-0.5 rounded border border-amber-300 bg-amber-50 text-amber-700">Gast · nur Lesen</span>
          )}
          <a href="/onboarding/index.html" class="text-sm text-slate-400 hover:text-slate-600" title="Einführung &amp; Rundgang">Rundgang</a>
          <span class="text-sm text-slate-500 hidden sm:block">{isGuest ? 'Gast' : access.user.email}</span>
          <form method="POST" action="/api/auth/logout">
            <button type="submit" class="text-sm text-slate-500 hover:text-slate-700 underline">{isGuest ? 'Verlassen' : 'Abmelden'}</button>
          </form>
        </div>
      </div>
    </header>

    <main class="flex-1 max-w-7xl mx-auto w-full px-6 py-12 relative">
      <div class="mb-12">
        <h1 class="text-4xl font-semibold text-slate-900 tracking-tight">Materialplattform ABU 2030</h1>
<a
          href="/onboarding/index.html"
          class="mt-6 inline-flex items-center gap-2 px-6 py-2.5 rounded-lg border text-base font-medium transition hover:bg-[var(--brand-tint)]"
          style="border-color: var(--brand); color: var(--brand)"
        >
          <span style="font-size:1.1em">📖</span> Rundgang ansehen &rarr;
        </a>
      </div>

      <!-- Primary: Einheiten + Einreichen -->
      <div class="grid gap-6 md:grid-cols-2 mb-8">
        {primaryTiles.map(t => (
          <a href={t.href} class="wappen-tile wappen-tile-primary group">
            <div class="wappen-lion" aria-hidden="true"></div>
            <div class="wappen-content">
              <h2 class="wappen-title">{t.title}</h2>
              <p class="wappen-blurb">{t.blurb}</p>
              {t.href === '/einheiten' && (
                <p class="wappen-eba-hint"><span aria-hidden="true">◷</span> EBA-Einheiten sind in Vorbereitung — aktuell sind die EFZ-Einheiten verfügbar.</p>
              )}
              <span class="wappen-cta">
                {t.cta}
                <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
                  <path d="M5 10h10M11 5l5 5-5 5" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>

      <!-- Secondary: Jahresplanung + Situationen (list) -->
      <div class="border-t border-slate-100 pt-5">
        <p class="text-xs text-slate-400 uppercase tracking-wider mb-4">Weitere Angebote</p>
        <div class="flex flex-col gap-3">
          <a href="/jahresplanung/uebersicht" class="inline-flex items-center gap-2 text-base text-slate-600 hover:text-[var(--brand)] transition-colors">
            Jahresplanung — alle Lehrjahre
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
              <path d="M5 10h10M11 5l5 5-5 5" />
            </svg>
          </a>
          <a href="/situationen" class="inline-flex items-center gap-2 text-base text-slate-600 hover:text-[var(--brand)] transition-colors">
            Sammlung Herausforderungen
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
              <path d="M5 10h10M11 5l5 5-5 5" />
            </svg>
          </a>
          <span class="inline-flex items-center gap-2 text-base text-slate-400 cursor-default select-none">
            Umsetzungsbeispiele
            <span class="text-xs font-medium px-1.5 py-0.5 rounded bg-slate-100 text-slate-400 tracking-wide">Demnächst</span>
          </span>
        </div>
      </div>
    </main>

    <footer class="border-t border-slate-200 py-4 px-6 text-center text-xs text-slate-400">
      Materialplattform · ABU Reform 2030 · BBW
    </footer>
  </div>

<style>
  .wappen-tile {
    position: relative;
    display: block;
    overflow: hidden;
    background: white;
    border: 1px solid #e2e8f0;
    border-top: 3px solid var(--brand);
    border-radius: 0.75rem;
    transition: border-color 0.18s, box-shadow 0.18s, transform 0.18s;
  }
  .wappen-tile-primary {
    padding: 2rem 1.75rem 1.75rem;
    min-height: 260px;
  }
  .wappen-tile-secondary {
    padding: 1.25rem 1.25rem 1rem;
    border-top-width: 2px;
    min-height: 0;
  }
  .wappen-tile:hover {
    border-color: var(--brand);
    box-shadow: 0 10px 24px -12px rgba(14, 110, 58, 0.35);
    transform: translateY(-2px);
  }
  .wappen-lion {
    position: absolute;
    right: -30px;
    top: -10px;
    width: 220px;
    height: 240px;
    background-image: url('/lion-only.svg');
    background-repeat: no-repeat;
    background-position: right center;
    background-size: contain;
    opacity: 0.05;
    color: var(--brand);
    transition: opacity 0.18s;
    pointer-events: none;
  }
  .wappen-tile:hover .wappen-lion {
    opacity: 0.09;
  }
  .wappen-content {
    position: relative;
    z-index: 1;
  }
  .wappen-mark {
    width: 2.75rem;
    height: 2.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--brand);
    border-radius: 0.5rem;
    color: var(--brand);
    font-weight: 700;
    font-size: 1.25rem;
    background: white;
    margin-bottom: 1rem;
  }
  .wappen-title {
    font-size: 1.35rem;
    font-weight: 600;
    color: #0f172a;
    margin-bottom: 0.6rem;
  }
  .wappen-blurb {
    font-size: 1rem;
    line-height: 1.6;
    color: #475569;
    margin-bottom: 1.5rem;
  }
  .wappen-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--brand);
  }
  .wappen-eba-hint {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    line-height: 1.4;
    color: var(--brand-dark);
    background: var(--brand-tint);
    border-radius: 0.4rem;
    padding: 0.4rem 0.6rem;
    margin-bottom: 1.25rem;
  }
  .wappen-tile:hover .wappen-cta,
  .wappen-tile:hover .wappen-cta-sm {
    color: var(--brand-dark);
  }
  .wappen-title-sm {
    font-size: 0.95rem;
    font-weight: 600;
    color: #0f172a;
    margin-bottom: 0.25rem;
  }
  .wappen-blurb-sm {
    font-size: 0.8rem;
    line-height: 1.5;
    color: #64748b;
    margin-bottom: 0.625rem;
  }
  .wappen-cta-sm {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--brand);
  }
</style>
</Base>
