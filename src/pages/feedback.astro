---
import LP from '../layouts/LP.astro'
import { getAccess, bounceKt1 } from '../lib/auth'
import { einheitenIndex, visibleEinheiten, type Role } from '../lib/einheiten'

const access = await getAccess(Astro)
if (!access) return Astro.redirect('/login')

const bounce = bounceKt1(Astro, access)
if (bounce) return bounce
if (access.role === 'gast') return Astro.redirect('/einheiten')

const role: Role = access.role === 'kt1' ? 'kt1' : 'lp'
const units = visibleEinheiten(einheitenIndex, role)
  .slice()
  .sort((a, b) => a.id.localeCompare(b.id, 'de'))
---
<LP title="Feedback / Material einreichen">
  <div class="max-w-3xl mx-auto">
    <a href="/" class="text-sm text-slate-500 hover:text-slate-700">← Hauptplattform</a>
    <h1 class="text-2xl font-semibold mt-2 mb-1">Feedback &amp; Material</h1>
    <p class="text-sm text-slate-500 mb-6">Wähle, worum es geht — du wirst zum passenden, schlanken Formular geführt.</p>

    <!-- Wurzel: BBW-Einheit vs. eigenes Material -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-4">
      <button type="button" class="tree-choice" data-branch="bbw" aria-pressed="false">
        <span class="tree-choice-title">Feedback zu einer BBW-Einheit</span>
        <span class="tree-choice-desc">Du hast eine Einheit aus dem Katalog unterrichtet und gibst Rückmeldung.</span>
      </button>
      <button type="button" class="tree-choice" data-branch="eigenes" aria-pressed="false">
        <span class="tree-choice-title">Eigenes Material einreichen</span>
        <span class="tree-choice-desc">Du hast eigenes Material erstellt und möchtest es teilen.</span>
      </button>
    </div>

    <!-- BBW-Zweig: Einheit + angepasst? -->
    <div id="bbw-step" class="hidden bg-white border border-slate-200 rounded-lg p-6 space-y-5">
      <div>
        <span class="field-label block mb-1">Welche Einheit hast du unterrichtet?</span>
        <select id="einheit-select" class="input">
          <option value="">— Einheit wählen —</option>
          {units.map((e) => (
            <option value={e.id}>{e.einheit_titel ? `${e.einheit_titel} · ${e.id}` : e.id}</option>
          ))}
        </select>
      </div>

      <div>
        <span class="field-label block mb-2">Hast du die Einheit angepasst?</span>
        <div class="radio-group" id="angepasst-group">
          <label class="radio-pill"><input type="radio" name="angepasst" value="nein" hidden /> Nein — 1:1 übernommen</label>
          <label class="radio-pill"><input type="radio" name="angepasst" value="ja" hidden /> Ja — verändert</label>
        </div>
        <p class="text-xs text-slate-500 mt-2" id="angepasst-hint"></p>
      </div>

      <div class="flex justify-end">
        <button type="button" id="bbw-weiter" class="px-4 py-2 rounded-md text-sm font-medium text-white opacity-50 cursor-not-allowed" style="background: var(--brand)" disabled>Weiter zum Feedback</button>
      </div>
    </div>
  </div>

  <style>
    .tree-choice {
      text-align: left; display: flex; flex-direction: column; gap: 0.35rem;
      padding: 1.1rem 1.2rem; border: 1px solid #cbd5e1; border-radius: 0.6rem; background: white;
      transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
    }
    .tree-choice:hover { border-color: var(--brand); box-shadow: 0 8px 20px -12px rgba(14,110,58,0.4); transform: translateY(-1px); }
    .tree-choice[aria-pressed="true"] { border-color: var(--brand); box-shadow: 0 0 0 3px var(--brand-ring); }
    .tree-choice-title { font-weight: 600; color: #0f172a; font-size: 1.05rem; }
    .tree-choice-desc { font-size: 0.8rem; line-height: 1.5; color: #64748b; }
  </style>

  <script is:inline>
    document.querySelectorAll('.radio-pill').forEach((pill) => {
      pill.addEventListener('click', () => {
        const input = pill.querySelector('input[type=radio]')
        if (!input) return
        document.querySelectorAll(`.radio-pill input[name="${input.name}"]`).forEach((o) => {
          o.checked = false; o.closest('.radio-pill').classList.remove('selected')
        })
        input.checked = true; pill.classList.add('selected')
        onAngepasstChange()
      })
    })

    const bbwStep = document.getElementById('bbw-step')
    const select = document.getElementById('einheit-select')
    const weiter = document.getElementById('bbw-weiter')
    const hint = document.getElementById('angepasst-hint')

    function angepasstValue() {
      return document.querySelector('input[name="angepasst"]:checked')?.value ?? ''
    }
    function onAngepasstChange() {
      const v = angepasstValue()
      hint.textContent = v === 'ja'
        ? 'Du lädst deine angepassten Dateien hoch und füllst denselben Feedback-Bogen aus.'
        : v === 'nein' ? 'Kurzer Feedback-Bogen, kein Upload nötig.' : ''
      refreshWeiter()
    }
    function refreshWeiter() {
      const ok = select.value && angepasstValue()
      weiter.disabled = !ok
      weiter.classList.toggle('opacity-50', !ok)
      weiter.classList.toggle('cursor-not-allowed', !ok)
    }

    document.querySelectorAll('.tree-choice').forEach((btn) => {
      btn.addEventListener('click', () => {
        const branch = btn.dataset.branch
        if (branch === 'eigenes') {
          window.location.href = '/eigenes-material'
          return
        }
        document.querySelectorAll('.tree-choice').forEach((b) => b.setAttribute('aria-pressed', String(b === btn)))
        bbwStep.classList.remove('hidden')
        bbwStep.scrollIntoView({ behavior: 'smooth', block: 'nearest' })
      })
    })

    select.addEventListener('change', refreshWeiter)
    weiter.addEventListener('click', () => {
      if (weiter.disabled) return
      const art = angepasstValue() === 'ja' ? 'angepasst' : '1zu1'
      window.location.href = `/einheiten/${encodeURIComponent(select.value)}/feedback?art=${art}`
    })
  </script>
</LP>
