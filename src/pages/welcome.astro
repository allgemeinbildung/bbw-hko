---
import Base from '../layouts/Base.astro'

if (Astro.locals.user) return Astro.redirect('/')

const guestError = Astro.url.searchParams.get('guest_error')
---
<Base title="Materialplattform · BBW">
  <div class="h-screen bg-white flex flex-col overflow-hidden">

    <!-- Slim header bar -->
    <header class="border-b border-slate-100 bg-white shrink-0">
      <div class="max-w-6xl mx-auto px-6 py-2 flex items-center justify-between">
        <img src="/logo-bbw-mark.png" alt="BBW Berufsbildungsschule Winterthur" class="logo-black h-10 w-auto" />
        <a href="/login" class="text-sm font-medium text-slate-600 hover:text-slate-900 transition">
          Anmelden &rarr;
        </a>
      </div>
    </header>

    <!-- Hero — fills remaining height, content centred -->
    <section class="flex-1 flex flex-col items-center justify-center px-6 py-4 text-center">

      <!-- Badge -->
      <div class="mb-6">
        <img
          src="/abu-2030-badge.png"
          alt="ABU Reform 2030"
          class="h-64 w-auto"
          onerror="this.style.display='none'"
        />
      </div>

      <h1 class="text-6xl font-bold text-slate-900 tracking-tight mb-3">
        Materialplattform
      </h1>
      <p class="text-xl text-slate-600 max-w-lg mb-2">
        Unterrichtseinheiten und Situationen für die <strong>ABU Reform 2030</strong>
      </p>
      <p class="text-lg text-slate-400 mb-10">
        Für Lehrpersonen der Berufsbildungsschule Winterthur
      </p>

      <!-- CTAs — primary action alone, secondary options smaller below -->
      <div class="flex flex-col items-center gap-5">
        <a
          href="/login"
          class="px-12 py-3.5 rounded-lg text-white font-semibold text-lg transition hover:opacity-90"
          style="background: var(--brand)"
        >
          Anmelden
        </a>

        <div class="flex flex-wrap gap-3 justify-center">
          <!-- Onboarding / tour — no login required -->
          <a
            href="/onboarding/index.html"
            class="px-6 py-2.5 rounded-lg border text-base font-medium transition hover:bg-[var(--brand-tint)]"
            style="border-color: var(--brand); color: var(--brand)"
          >
            Rundgang ansehen &rarr;
          </a>
          <!-- Guest access (read-only, no code required) -->
          <form method="POST" action="/api/auth/guest">
            <button
              type="submit"
              class="px-6 py-2.5 rounded-lg border border-slate-300 text-slate-700 text-base font-medium hover:bg-slate-50 transition"
            >
              Als Gast ansehen
            </button>
          </form>
        </div>
      </div>

      {guestError && (
        <p class="mt-4 text-sm text-red-600">{decodeURIComponent(guestError)}</p>
      )}

      <p class="mt-6 text-sm text-slate-400 max-w-lg">
        Die Plattform ist nur auf Einladung zugänglich. Ein Konto erstellst du über die
        <a href="/login" class="underline hover:text-slate-600">Anmeldeseite</a> — einen Einladungscode erhältst du bei
        <a href="mailto:pietro.rossi@bbw.ch?subject=Zugang%20ABU-Materialplattform" class="underline hover:text-slate-600">pietro.rossi@bbw.ch</a>.
        <strong>Rundgang</strong> und <strong>Gast-Zugang</strong> zeigen die Inhalte ohne eigenes Konto.
      </p>

    </section>

    <footer class="border-t border-slate-100 shrink-0 py-3 px-6 text-center text-xs text-slate-400">
      BBW Berufsbildungsschule Winterthur &middot; ABU Reform 2030
    </footer>

  </div>
</Base>
