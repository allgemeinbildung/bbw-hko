---
import Base from '../layouts/Base.astro'

if (Astro.locals.user) return Astro.redirect('/')
---
<Base title="Materialplattform · BBW">
  <div class="h-screen bg-white flex flex-col overflow-hidden">

    <!-- Slim header bar -->
    <header class="border-b border-slate-100 bg-white shrink-0">
      <div class="max-w-6xl mx-auto px-6 py-2 flex items-center justify-between">
        <img src="/logo-bbw-mark.png" alt="BBW Berufsbildungsschule Winterthur" class="logo-black h-10 w-auto" />
        <a href="/login" class="text-sm font-medium text-slate-600 hover:text-slate-900 transition">
          Anmelden &rarr;
        </a>
      </div>
    </header>

    <!-- Hero — fills remaining height, content centred -->
    <section class="flex-1 flex flex-col items-center justify-center px-6 py-4 text-center">

      <!-- Badge -->
      <div class="mb-6">
        <img
          src="/abu-2030-badge.png"
          alt="ABU Reform 2030"
          class="h-64 w-auto"
          onerror="this.style.display='none'"
        />
      </div>

      <h1 class="text-6xl font-bold text-slate-900 tracking-tight mb-3">
        Materialplattform
      </h1>
      <p class="text-xl text-slate-600 max-w-lg mb-2">
        Unterrichtseinheiten und Situationen für die <strong>ABU Reform 2030</strong>
      </p>
      <p class="text-lg text-slate-400 mb-10">
        Für Lehrpersonen der Berufsbildungsschule Winterthur
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href="/login"
          class="px-9 py-3 rounded-lg text-white font-semibold text-lg transition hover:opacity-90"
          style="background: var(--brand)"
        >
          Anmelden
        </a>
        <a
          href="/registrieren"
          class="px-9 py-3 rounded-lg border border-slate-300 text-slate-700 font-medium text-lg hover:bg-slate-50 transition"
        >
          Konto erstellen
        </a>
        <!-- Onboarding / tour — for first-time visitors and KT1 showcasing, no login required -->
        <a
          href="/onboarding/index.html"
          class="px-9 py-3 rounded-lg border font-semibold text-lg transition hover:bg-[var(--brand-tint)]"
          style="border-color: var(--brand); color: var(--brand)"
        >
          Rundgang ansehen &rarr;
        </a>
      </div>

      <p class="mt-6 text-sm text-slate-400">
        Neu hier? Der Rundgang erklärt die Plattform Schritt für Schritt &mdash; ganz ohne Login.
      </p>

    </section>

    <footer class="border-t border-slate-100 shrink-0 py-3 px-6 text-center text-xs text-slate-400">
      BBW Berufsbildungsschule Winterthur &middot; ABU Reform 2030
    </footer>

  </div>
</Base>
