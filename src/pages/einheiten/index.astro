---
import Einheiten from '../../layouts/Einheiten.astro'
import Glossar from '../../components/Glossar.astro'
import { applyEinheitenFilters, einheitenIndex, emptyEinheitenFilters, visibleEinheiten, isEntwurf, draftKomponenten, KOMPONENTEN_LABEL } from '../../lib/einheiten'

const user = Astro.locals.user
if (!user) return Astro.redirect('/login')

const { data: profile } = await Astro.locals.supabase
  .from('profiles')
  .select('role')
  .eq('id', user.id)
  .single()

const role: 'lp' | 'kt1' | 'gast' =
  profile?.role === 'kt1' ? 'kt1' : profile?.role === 'gast' ? 'gast' : 'lp'

const p = Astro.url.searchParams
const filters = {
  ...emptyEinheitenFilters(),
  thema_nr: p.get('thema_nr') ?? '',
  lehrgang: p.get('lehrgang') ?? '',
  aspekt: p.get('aspekt') ?? '',
  sk: p.get('sk') ?? '',
  q: p.get('q') ?? '',
}

// Sichtbarkeit nach Rolle: lp/gast sehen nur publizierte Einheiten, KT1 alle.
const sichtbar = visibleEinheiten(einheitenIndex, role)
const filtered = applyEinheitenFilters(sichtbar, filters)

// Aufteilung nach Grundbildungstyp: EFZ (3-/4-jährig) oben, EBA (2-jährig) unten.
const isEba = (l: string | undefined | null) => (l ?? '').toUpperCase().startsWith('EBA')
const efzEinheiten = filtered.filter((e) => !isEba(e.lehrgang))
const ebaEinheiten = filtered.filter((e) => isEba(e.lehrgang))

// Filter-UI vorerst ausgeblendet (erst 2 Einheiten, alle T1 / 1.1.1). Auf `true` setzen,
// sobald Einheiten aus verschiedenen Themen/Kompetenzen dazukommen → reaktiviert das Formular.
// Die Filterlogik (URL-Query-Params) bleibt aktiv, nur die Bedienoberfläche ist verborgen.
const SHOW_FILTER = false

const allAspekte = Array.from(new Set(einheitenIndex.flatMap((e) => e.aspekte))).sort()
const allThemen = Array.from(new Set(einheitenIndex.map((e) => e.thema_nr).filter((n): n is number => n != null))).sort()
const allLehrgaenge = Array.from(new Set(einheitenIndex.map((e) => e.lehrgang))).sort()
---
<Einheiten title="Unterrichtseinheiten" role={role}>
  <div class="mb-5 flex items-end justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold">Unterrichtseinheiten-Katalog</h1>
      <p class="text-sm text-slate-500 mt-1">
        {SHOW_FILTER ? `${filtered.length} von ${sichtbar.length}` : sichtbar.length} Unterrichtseinheiten · inkl. 3 Herausforderungen + KN + Begleitdokument
      </p>
    </div>
    <p class="text-xs text-slate-500 max-w-md text-right hidden md:block">
      Wähle eine Einheit, lade das Bundle (HTML + Word) herunter, unterrichte
      — und gib im Anschluss Feedback.
    </p>
  </div>

  {SHOW_FILTER && (
  <form method="get" class="bg-white border border-slate-200 rounded-lg p-4 mb-6 flex flex-wrap gap-3 items-end">
    <label class="flex flex-col gap-1">
      <span class="field-label">Suche</span>
      <input type="text" name="q" value={filters.q} placeholder="Stichwort..." class="input" style="min-width:14rem" />
    </label>
    <label class="flex flex-col gap-1">
      <span class="field-label">Thema</span>
      <select name="thema_nr" class="input" style="min-width:7rem">
        <option value="">— alle —</option>
        {allThemen.map((t) => <option value={String(t)} selected={filters.thema_nr === String(t)}>T{t}</option>)}
      </select>
    </label>
    <label class="flex flex-col gap-1">
      <span class="field-label">Lehrgang</span>
      <select name="lehrgang" class="input" style="min-width:9rem">
        <option value="">— alle —</option>
        {allLehrgaenge.map((l) => <option value={l} selected={filters.lehrgang === l}>{l}</option>)}
      </select>
    </label>
    <label class="flex flex-col gap-1">
      <span class="field-label">Aspekt</span>
      <select name="aspekt" class="input" style="min-width:14rem">
        <option value="">— alle —</option>
        {allAspekte.map((a) => <option value={a} selected={filters.aspekt === a}>{a}</option>)}
      </select>
    </label>
    <button type="submit" class="px-4 py-2 rounded-md text-sm font-medium text-white" style="background: var(--brand)">Filtern</button>
    <a href="/einheiten" class="px-4 py-2 rounded-md text-sm text-slate-500 underline">Reset</a>
  </form>
  )}

  {/* ── EFZ – Berufliche Grundbildung (3-/4-jährig) ───────────────────── */}
  <section class="mb-10">
    <div class="flex items-baseline gap-3 mb-4 pb-2 border-b-2" style="border-color: var(--brand)">
      <h2 class="text-lg font-semibold text-slate-900">EFZ – Berufliche Grundbildung</h2>
      <span class="text-xs text-slate-500">3-/4-jährig · {efzEinheiten.length} {efzEinheiten.length === 1 ? 'Einheit' : 'Einheiten'}</span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {efzEinheiten.map((e) => (
        <div class="lion-bg bg-white border border-slate-200 rounded-lg hover:shadow-md hover:border-[var(--brand)] transition flex flex-col">
          <a href={`/einheiten/${e.id}`} class="block p-5 flex-1">
            <h3 class="text-base font-semibold text-slate-900 leading-snug mb-1">
              {e.einheit_titel}
            </h3>
            {role === 'kt1' && (isEntwurf(e) || draftKomponenten(e).length > 0) && (
              <div class="flex flex-wrap gap-1.5 mb-2">
                {isEntwurf(e) && (
                  <span class="inline-flex items-center gap-1 text-[11px] font-semibold px-2 py-0.5 rounded-full bg-amber-100 text-amber-800 border border-amber-200">
                    ● Entwurf · nur KT1
                  </span>
                )}
                {!isEntwurf(e) && draftKomponenten(e).map((k) => (
                  <span class="inline-flex items-center gap-1 text-[11px] font-semibold px-2 py-0.5 rounded-full bg-amber-50 text-amber-700 border border-amber-200">
                    ● {KOMPONENTEN_LABEL[k] ?? k} im Entwurf · nur KT1
                  </span>
                ))}
              </div>
            )}
            <div class="flex flex-wrap gap-1.5 mb-2">
              {e.thema_nr != null && <span class="thema-chip" data-thema={e.thema_nr} title={`Thema ${e.thema_nr}`}>T{e.thema_nr}</span>}
              {(e.abgedeckte_kompetenzen?.length ? e.abgedeckte_kompetenzen : [e.kompetenz_nr]).map((k) => (
                <span class="chip chip-blue">Kompetenz {k}</span>
              ))}
            </div>
            <p class="text-sm text-slate-600 leading-snug line-clamp-3">{e.titel}</p>
          </a>
          <div class="px-5 pb-4 pt-2 border-t border-slate-100 flex items-center gap-3">
            <a href={`/einheiten/${e.id}`} class="font-medium text-sm flex-1" style="color: var(--brand)">
              Öffnen →
            </a>
            {e.hat_begleiter && (
              <a
                href={`/einheiten/${e.id}/begleiter`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-xs font-medium px-3 py-1.5 rounded-md border transition whitespace-nowrap"
                style="color: var(--brand-dark); border-color: var(--brand); background: var(--brand-tint);"
              >
                Lies mich!
              </a>
            )}
          </div>
        </div>
      ))}
    </div>

    {efzEinheiten.length === 0 && (
      <div class="bg-white border border-slate-200 rounded-lg p-8 text-center text-slate-500 text-sm">
        Keine EFZ-Einheiten gefunden.
      </div>
    )}
  </section>

  {/* ── EBA – Zweijährige Grundbildung ────────────────────────────────── */}
  <section class="mb-10">
    <div class="flex items-baseline gap-3 mb-4 pb-2 border-b-2" style="border-color: var(--brand)">
      <h2 class="text-lg font-semibold text-slate-900">EBA – Zweijährige Grundbildung</h2>
      <span class="text-xs text-slate-500">2-jährig · {ebaEinheiten.length} {ebaEinheiten.length === 1 ? 'Einheit' : 'Einheiten'}</span>
    </div>

    {ebaEinheiten.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" data-lehrgang="EBA">
        {ebaEinheiten.map((e) => (
          <div class="lion-bg bg-white border border-slate-200 rounded-lg hover:shadow-md hover:border-[var(--brand)] transition flex flex-col">
            <a href={`/einheiten/${e.id}`} class="block p-5 flex-1">
              <h3 class="text-base font-semibold text-slate-900 leading-snug mb-1">
                {e.einheit_titel}
              </h3>
              {role === 'kt1' && (isEntwurf(e) || draftKomponenten(e).length > 0) && (
                <div class="flex flex-wrap gap-1.5 mb-2">
                  {isEntwurf(e) && (
                    <span class="inline-flex items-center gap-1 text-[11px] font-semibold px-2 py-0.5 rounded-full bg-amber-100 text-amber-800 border border-amber-200">
                      ● Entwurf · nur KT1
                    </span>
                  )}
                  {!isEntwurf(e) && draftKomponenten(e).map((k) => (
                    <span class="inline-flex items-center gap-1 text-[11px] font-semibold px-2 py-0.5 rounded-full bg-amber-50 text-amber-700 border border-amber-200">
                      ● {KOMPONENTEN_LABEL[k] ?? k} im Entwurf · nur KT1
                    </span>
                  ))}
                </div>
              )}
              <div class="flex flex-wrap gap-1.5 mb-2">
                {e.thema_nr != null && <span class="thema-chip" data-thema={e.thema_nr} title={`Thema ${e.thema_nr}`}>T{e.thema_nr}</span>}
                {(e.abgedeckte_kompetenzen?.length ? e.abgedeckte_kompetenzen : [e.kompetenz_nr]).map((k) => (
                  <span class="chip chip-blue">Kompetenz {k}</span>
                ))}
              </div>
              <p class="text-sm text-slate-600 leading-snug line-clamp-3">{e.titel}</p>
            </a>
            <div class="px-5 pb-4 pt-2 border-t border-slate-100 flex items-center gap-3">
              <a href={`/einheiten/${e.id}`} class="font-medium text-sm flex-1" style="color: var(--brand)">
                Öffnen →
              </a>
              {e.hat_begleiter && (
                <a
                  href={`/einheiten/${e.id}/begleiter`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-xs font-medium px-3 py-1.5 rounded-md border transition whitespace-nowrap"
                  style="color: var(--brand-dark); border-color: var(--brand); background: var(--brand-tint);"
                >
                  Lies mich!
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    )}

    {ebaEinheiten.length === 0 && (
      <p class="text-sm text-slate-400 italic">Noch keine EBA-Einheiten aufgeschaltet.</p>
    )}
  </section>

  {ebaEinheiten.length === 0 && (
    <div class="rounded-lg px-4 py-3 flex items-start gap-3 border" style="border-color: var(--brand); background: var(--brand-tint)">
      <span class="text-lg leading-none" style="color: var(--brand-dark)" aria-hidden="true">◷</span>
      <p class="text-sm text-slate-700 m-0">
        <strong style="color: var(--brand-dark)">EBA – in Vorbereitung.</strong>
        Einheiten für die zweijährige Grundbildung (EBA) entstehen gerade und werden in Kürze hier aufgeschaltet. Aktuell sind die EFZ-Einheiten sichtbar.
      </p>
    </div>
  )}

  <div class="mt-8">
    <Glossar />
  </div>
</Einheiten>
