---
import Einheiten from '../../../layouts/Einheiten.astro'
import { einheitById } from '../../../lib/einheiten'
import { knTypLabel } from '../../../lib/einheiten/kn-typ-labels'

const user = Astro.locals.user
if (!user) return Astro.redirect('/login')

const setKey = Astro.params.setKey!
const meta = einheitById(setKey)
if (!meta) return new Response('Einheit nicht gefunden', { status: 404 })

const { data: profile } = await Astro.locals.supabase
  .from('profiles')
  .select('role, abteilung')
  .eq('id', user.id)
  .single()

if (profile?.role === 'gast') return Astro.redirect(`/einheiten/${setKey}`)
const role: 'lp' | 'kt1' = profile?.role === 'kt1' ? 'kt1' : 'lp'
const defaultAbteilung = profile?.abteilung ?? ''

const knTypen = meta.kn_typen

// Vorauswahl aus dem zentralen /feedback-Entscheidungsbaum (?art=1zu1|angepasst)
const preArtRaw = Astro.url.searchParams.get('art')
const preArt = preArtRaw === '1zu1' || preArtRaw === 'angepasst' ? preArtRaw : ''
---
<Einheiten title={`Feedback · ${meta.einheit_titel}`} role={role}>
  <div class="max-w-3xl mx-auto">
    <a href={`/einheiten/${setKey}`} class="text-sm text-slate-500 hover:text-slate-700">← Zurück zur Einheit</a>
    <h1 class="text-2xl font-semibold mt-2 mb-1">Feedback nach Unterricht</h1>
    <p class="text-sm text-slate-500 mb-6">
      Einheit <strong>{meta.einheit_titel}</strong> — {meta.titel}
    </p>

    <!-- Schritt 1: Entscheidungsbaum -->
    <div id="art-step" class="mb-2">
      <h2 class="text-base font-semibold text-slate-900 mb-3">Wie hast du das Material genutzt?</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <button type="button" class="art-choice" data-art="1zu1">
          <span class="art-choice-title">1:1 übernommen</span>
          <span class="art-choice-desc">Ich habe die Einheit unverändert unterrichtet. Kurzes Feedback, kein Upload.</span>
        </button>
        <button type="button" class="art-choice" data-art="angepasst">
          <span class="art-choice-title">Angepasst</span>
          <span class="art-choice-desc">Ich habe die vorgegebene Einheit verändert. Gleiches Feedback plus Upload der angepassten Dateien.</span>
        </button>
      </div>
      <p class="text-xs text-slate-500 mt-3">
        Komplett eigenes Material erstellt? →
        <a href="/eigenes-material" class="underline text-slate-600 hover:text-slate-900">Eigenes Material teilen</a>
      </p>
    </div>

    <div id="fb-msg" class="text-sm mb-4 hidden"></div>

    <!-- Schritt 2: schlanker Feedback-Bogen (erst nach Auswahl sichtbar) -->
    <form id="fb-form" data-pre-art={preArt} class="space-y-6 bg-white border border-slate-200 rounded-lg p-6 hidden">
      <input type="hidden" name="einheit_id" value={setKey} />
      <input type="hidden" name="feedback_art" id="feedback-art" value="" />

      <div class="flex items-center gap-2 -mt-1">
        <span class="text-xs text-slate-500">Genutzt als:</span>
        <span id="art-badge" class="text-xs font-semibold px-2 py-0.5 rounded-full"></span>
        <button type="button" id="art-change" class="text-xs underline text-slate-500 hover:text-slate-700">ändern</button>
      </div>

      <!-- Kontext -->
      <section>
        <h2 class="text-base font-semibold text-slate-900 mb-3">Wann und mit wem hast du unterrichtet?</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <label class="flex flex-col gap-1">
            <span class="field-label">Klasse</span>
            <input class="input" name="klasse" placeholder="z.B. FaGe24a" />
          </label>
          <label class="flex flex-col gap-1">
            <span class="field-label">Lehrjahr</span>
            <input class="input" type="number" name="lehrjahr" min="1" max="4" />
          </label>
          <label class="flex flex-col gap-1">
            <span class="field-label">Abteilung</span>
            <input class="input" name="abteilung" value={defaultAbteilung} />
          </label>
          <label class="flex flex-col gap-1">
            <span class="field-label">Dauer (Lektionen)</span>
            <input class="input" type="number" name="dauer_lektionen" step="0.5" min="0" />
          </label>
          <label class="flex flex-col gap-1">
            <span class="field-label">Getestet von</span>
            <input class="input" type="date" name="getestet_von" />
          </label>
          <label class="flex flex-col gap-1">
            <span class="field-label">bis</span>
            <input class="input" type="date" name="getestet_bis" />
          </label>
        </div>
      </section>

      <!-- Komponenten -->
      <section>
        <h2 class="text-base font-semibold text-slate-900 mb-3">Welche Komponenten hast du eingesetzt?</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-2 mb-3">
          <label class="check-item"><input type="checkbox" name="genutzt_sit_a" checked /> Herausforderung A</label>
          <label class="check-item"><input type="checkbox" name="genutzt_sit_b" checked /> Herausforderung B</label>
          <label class="check-item"><input type="checkbox" name="genutzt_sit_c" checked /> Herausforderung C</label>
          <label class="check-item"><input type="checkbox" name="genutzt_kn" id="genutzt-kn-cb" checked /> KN</label>
        </div>
        {knTypen.length > 0 && (
          <label class="flex flex-col gap-1">
            <span class="field-label">KN-Typ verwendet</span>
            <select class="input" name="kn_typ_verwendet">
              <option value="">— keine Auswahl —</option>
              {knTypen.map((t) => <option value={t.typ}>{knTypLabel(t.typ, t.label)}</option>)}
            </select>
          </label>
        )}
      </section>

      <!-- Angepasst: was verändert + Upload -->
      <section id="angepasst-section" class="hidden rounded-lg border border-amber-200 bg-amber-50/60 p-4">
        <h2 class="text-base font-semibold text-slate-900 mb-3">Deine Anpassung</h2>
        <label class="flex flex-col gap-1 mb-4">
          <span class="field-label">Was hast du angepasst? <span class="text-red-500">*</span></span>
          <textarea class="input" name="eigene_anpassungen" rows="3" placeholder="Beschreibe kurz, was du an der Einheit verändert hast (z.B. berufsspezifische Einstiegssituation, gekürzte Aufträge …)."></textarea>
        </label>
        <div>
          <span class="field-label block mb-1">Angepasste Dateien hochladen</span>
          <p class="text-xs text-slate-500 mb-2">PDF, HTML oder Word (DOCX). Mehrere Dateien möglich, max. 15 MB/Datei.</p>
          <div id="idee-file-list" class="space-y-1 mb-2"></div>
          <p id="idee-upload-hint" class="text-xs text-amber-600 hidden">Speichere zuerst als Entwurf, um Dateien hochzuladen.</p>
          <input type="file" multiple id="idee-files" accept=".pdf,.html,.htm,.doc,.docx" class="text-sm text-slate-600" />
        </div>
      </section>

      <!-- Bewertung (unverändert beibehalten) -->
      <section>
        <h2 class="text-base font-semibold text-slate-900 mb-3">Bewertung (1 = sehr schwach … 5 = sehr stark)</h2>
        <div class="space-y-3">
          {[
            ['tauglichkeit', 'Passt die Einheit in den Unterricht?'],
            ['qualitaet_situation', 'Qualität der Herausforderungen'],
            ['qualitaet_handlungsprodukt', 'Qualität des Handlungsprodukts'],
            ['schwierigkeit', 'Anspruch für die Lernenden'],
            ['motivation', 'Engagement der Lernenden'],
            ['kn_validitaet', 'KN: hat er die Kompetenz wirklich gemessen?'],
          ].map(([k, label]) => (
            <div class="flex items-center justify-between gap-3">
              <span class="text-sm text-slate-700">{label}</span>
              <div class="radio-group">
                {[1, 2, 3, 4, 5].map((v) => (
                  <label class="radio-pill">
                    <input type="radio" name={k} value={v} hidden /> {v}
                  </label>
                ))}
              </div>
            </div>
          ))}

          <!-- Niveau-Passung -->
          <div class="pt-3 border-t border-slate-100">
            <div class="flex items-center justify-between gap-3 flex-wrap">
              <span class="text-sm text-slate-700">Niveau-Passung</span>
              <div class="radio-group">
                <label class="radio-pill"><input type="radio" name="niveau_passung" value="zu_leicht" hidden /> Zu leicht</label>
                <label class="radio-pill"><input type="radio" name="niveau_passung" value="passend" hidden /> Passend</label>
                <label class="radio-pill"><input type="radio" name="niveau_passung" value="zu_schwer" hidden /> Zu schwer</label>
              </div>
            </div>
            <div id="scaffolding-wrap" class="hidden mt-2">
              <label class="flex flex-col gap-1">
                <span class="field-label">Nötiges Scaffolding / Anpassungsbedarf</span>
                <textarea class="input" name="noetiges_scaffolding" rows="2" placeholder="Was brauchen die Lernenden zusätzlich?"></textarea>
              </label>
            </div>
          </div>

          <div class="flex items-center justify-between gap-3 pt-2 border-t border-slate-100">
            <span class="text-sm text-slate-700">Würdest du diese Einheit weiteren LP empfehlen?</span>
            <div class="radio-group">
              <label class="radio-pill"><input type="radio" name="weiterempfehlung" value="true" hidden /> Ja</label>
              <label class="radio-pill"><input type="radio" name="weiterempfehlung" value="false" hidden /> Nein</label>
            </div>
          </div>
        </div>
      </section>

      <!-- KN-Erfolg — sichtbar wenn genutzt_kn aktiv -->
      <section id="kn-erfolg-section">
        <h2 class="text-base font-semibold text-slate-900 mb-3">Erfolg des Kompetenznachweises</h2>
        <div class="space-y-3">
          {[
            ['kn_fairness', 'Fairness (alle hatten eine faire Chance)'],
            ['kn_zeit_angemessen', 'Zeit angemessen'],
            ['kn_raster_brauchbar', 'Beurteilungsraster brauchbar'],
          ].map(([k, label]) => (
            <div class="flex items-center justify-between gap-3">
              <span class="text-sm text-slate-700">{label}</span>
              <div class="radio-group">
                {[1, 2, 3, 4, 5].map((v) => (
                  <label class="radio-pill">
                    <input type="radio" name={k} value={v} hidden /> {v}
                  </label>
                ))}
              </div>
            </div>
          ))}
          <label class="flex flex-col gap-1">
            <span class="field-label">Bestehensquote (Ergebnis-Bucket)</span>
            <select class="input" name="kn_ergebnis">
              <option value="">— keine Angabe —</option>
              <option value="unter_50">&lt; 50 %</option>
              <option value="50_75">50 – 75 %</option>
              <option value="75_90">75 – 90 %</option>
              <option value="ueber_90">&gt; 90 %</option>
            </select>
          </label>
        </div>
      </section>

      <!-- Ein Freitextfeld statt sechs -->
      <section>
        <label class="flex flex-col gap-1">
          <span class="field-label">Was ist dir aufgefallen? (optional)</span>
          <textarea class="input" name="anmerkungen" rows="3" placeholder="Was hat funktioniert, was nicht, Änderungsideen — kurz in eigenen Worten."></textarea>
        </label>
      </section>

      <div class="flex items-center justify-end gap-3">
        <button type="button" id="save-draft" class="px-4 py-2 rounded-md text-sm font-medium border border-slate-300 text-slate-700 hover:bg-slate-50">Als Entwurf speichern</button>
        <button type="button" id="submit-final" class="px-4 py-2 rounded-md text-sm font-medium text-white" style="background: var(--brand)">Feedback einreichen</button>
      </div>
    </form>
  </div>

  <style>
    .art-choice {
      text-align: left;
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      padding: 1rem 1.1rem;
      border: 1px solid #cbd5e1;
      border-radius: 0.6rem;
      background: white;
      transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
    }
    .art-choice:hover {
      border-color: var(--brand);
      box-shadow: 0 8px 20px -12px rgba(14, 110, 58, 0.4);
      transform: translateY(-1px);
    }
    .art-choice-title { font-weight: 600; color: #0f172a; font-size: 1.05rem; }
    .art-choice-desc { font-size: 0.8rem; line-height: 1.5; color: #64748b; }
  </style>

  <script is:inline>
    // Radio-pill click behaviour
    document.querySelectorAll('.radio-pill').forEach((pill) => {
      pill.addEventListener('click', () => {
        const input = pill.querySelector('input[type=radio]')
        if (!input) return
        document.querySelectorAll(`.radio-pill input[name="${input.name}"]`).forEach((other) => {
          other.checked = false
          other.closest('.radio-pill').classList.remove('selected')
        })
        input.checked = true
        pill.classList.add('selected')
      })
    })
    document.querySelectorAll('.check-item input[type=checkbox]').forEach((cb) => {
      const apply = () => cb.closest('.check-item').classList.toggle('checked', cb.checked)
      apply(); cb.addEventListener('change', apply)
    })

    // ── Entscheidungsbaum ────────────────────────────────────────────────
    const artStep = document.getElementById('art-step')
    const form = document.getElementById('fb-form')
    const artInput = document.getElementById('feedback-art')
    const artBadge = document.getElementById('art-badge')
    const angepasstSection = document.getElementById('angepasst-section')

    function selectArt(art) {
      artInput.value = art
      const isAngepasst = art === 'angepasst'
      angepasstSection.classList.toggle('hidden', !isAngepasst)
      artBadge.textContent = isAngepasst ? 'Angepasst' : '1:1 übernommen'
      artBadge.className = 'text-xs font-semibold px-2 py-0.5 rounded-full ' +
        (isAngepasst ? 'bg-amber-100 text-amber-800' : 'bg-emerald-100 text-emerald-800')
      artStep.classList.add('hidden')
      form.classList.remove('hidden')
      window.scrollTo({ top: 0, behavior: 'smooth' })
    }
    document.querySelectorAll('.art-choice').forEach((btn) => {
      btn.addEventListener('click', () => selectArt(btn.dataset.art))
    })
    document.getElementById('art-change').addEventListener('click', () => {
      form.classList.add('hidden')
      artStep.classList.remove('hidden')
    })

    // Vorauswahl aus dem zentralen /feedback-Entscheidungsbaum → Auswahlschritt überspringen
    const preArt = form.dataset.preArt
    if (preArt === '1zu1' || preArt === 'angepasst') selectArt(preArt)

    // KN checkbox → toggle KN-Erfolg section
    const knCb = document.getElementById('genutzt-kn-cb')
    const knSection = document.getElementById('kn-erfolg-section')
    function syncKn() { knSection.classList.toggle('hidden', !knCb.checked) }
    syncKn(); knCb.addEventListener('change', syncKn)

    // Niveau-Passung → scaffolding reveal
    document.querySelectorAll('input[name="niveau_passung"]').forEach((r) => {
      r.addEventListener('change', () => {
        const val = document.querySelector('input[name="niveau_passung"]:checked')?.value
        document.getElementById('scaffolding-wrap').classList.toggle('hidden', val === 'passend' || !val)
      })
    })

    // State: feedback row id returned after first save
    let savedFeedbackId = null

    function gather(status) {
      const fd = new FormData(form)
      const obj = { status }
      const intFields = ['lehrjahr','tauglichkeit','qualitaet_situation','qualitaet_handlungsprodukt',
        'schwierigkeit','motivation','kn_validitaet','kn_fairness','kn_zeit_angemessen','kn_raster_brauchbar']
      for (const [k, v] of fd.entries()) {
        if (v === '' || v == null) continue
        if (k === 'weiterempfehlung') obj[k] = v === 'true'
        else if (intFields.includes(k)) obj[k] = parseInt(v, 10)
        else if (k === 'dauer_lektionen') obj[k] = parseFloat(v)
        else obj[k] = v
      }
      // Explicit booleans for checkboxes not in FormData when unchecked
      ;['genutzt_sit_a','genutzt_sit_b','genutzt_sit_c','genutzt_kn'].forEach((k) => {
        const el = form.querySelector(`[name="${k}"]`)
        obj[k] = !!(el && el.checked)
      })
      return obj
    }

    function hasQueuedFiles() {
      const input = document.getElementById('idee-files')
      return !!(input && input.files && input.files.length > 0)
    }

    async function uploadIdeeDateien() {
      const input = document.getElementById('idee-files')
      if (!input || !input.files || input.files.length === 0 || !savedFeedbackId) return
      const fd = new FormData()
      for (const f of input.files) fd.append('files', f)
      const res = await fetch(`/api/einheit-feedbacks/${savedFeedbackId}/files`, { method: 'POST', body: fd })
      const body = await res.json().catch(() => ({}))
      if (!res.ok) throw new Error(body.error || 'Upload fehlgeschlagen.')
      input.value = ''
      renderFileList(body.data ?? [])
    }

    function renderFileList(files) {
      const list = document.getElementById('idee-file-list')
      list.innerHTML = ''
      files.forEach((f) => {
        const li = document.createElement('div')
        li.className = 'flex items-center justify-between text-sm bg-white border border-slate-200 rounded px-3 py-1.5'
        li.innerHTML = `<a href="/api/einheit-feedbacks/${savedFeedbackId}/files?path=${encodeURIComponent(f.path)}" target="_blank" class="underline text-slate-700 truncate">${f.name}</a>
          <button class="ml-3 text-red-500 hover:text-red-700 text-xs shrink-0" data-path="${f.path}">Entfernen</button>`
        li.querySelector('button').addEventListener('click', async () => {
          const res = await fetch(`/api/einheit-feedbacks/${savedFeedbackId}/files?path=${encodeURIComponent(f.path)}`, { method: 'DELETE' })
          const body = await res.json().catch(() => ({}))
          if (res.ok) renderFileList(body.data ?? [])
          else alert('Fehler: ' + (body.error || res.statusText))
        })
        list.appendChild(li)
      })
    }

    async function send(status) {
      const msg = document.getElementById('fb-msg')
      const payload = gather(status)

      if (payload.feedback_art === 'angepasst' && !payload.eigene_anpassungen?.trim()) {
        msg.textContent = 'Bitte beschreibe kurz, was du angepasst hast.'
        msg.className = 'text-sm text-red-600'
        msg.classList.remove('hidden')
        angepasstSection.scrollIntoView({ behavior: 'smooth', block: 'center' })
        return
      }

      msg.textContent = 'Speichere…'
      msg.className = 'text-sm text-slate-500'
      msg.classList.remove('hidden')

      try {
        let res
        if (savedFeedbackId) {
          res = await fetch(`/api/einheit-feedbacks/${savedFeedbackId}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          })
        } else {
          res = await fetch('/api/einheit-feedbacks', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          })
        }
        const body = await res.json().catch(() => ({}))
        if (!res.ok) throw new Error(body.error || res.statusText)
        if (body.data?.id) savedFeedbackId = body.data.id

        // Datei-Upload jetzt möglich (nur angepasst)
        document.getElementById('idee-upload-hint')?.classList.add('hidden')

        let uploadError = null
        if (savedFeedbackId && hasQueuedFiles()) {
          try { await uploadIdeeDateien() } catch (e) { uploadError = e }
        }

        if (status === 'eingereicht') {
          if (uploadError) {
            msg.textContent = 'Feedback gespeichert, aber der Datei-Upload ist fehlgeschlagen: ' + uploadError.message + ' Du kannst die Datei unten erneut hochladen.'
            msg.className = 'text-sm text-amber-600'
          } else {
            window.location.href = '/einheiten?success=Feedback+eingereicht.+Danke!'
          }
        } else {
          msg.textContent = uploadError
            ? 'Entwurf gespeichert, aber der Datei-Upload ist fehlgeschlagen: ' + uploadError.message
            : 'Entwurf gespeichert.'
          msg.className = uploadError ? 'text-sm text-amber-600' : 'text-sm text-emerald-600'
        }
      } catch (err) {
        msg.textContent = 'Fehler beim Speichern: ' + err.message
        msg.className = 'text-sm text-red-600'
      }
    }

    document.getElementById('save-draft').addEventListener('click', () => send('entwurf'))
    document.getElementById('submit-final').addEventListener('click', () => send('eingereicht'))
  </script>
</Einheiten>
