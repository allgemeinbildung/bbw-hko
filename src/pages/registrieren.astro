---
import Base from '../layouts/Base.astro'

if (Astro.locals.user) return Astro.redirect('/')

const error = Astro.url.searchParams.get('error')
const success = Astro.url.searchParams.get('success')
---
<Base title="Registrieren">
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-sm bg-white border border-slate-200 rounded-xl p-8 shadow-sm">

      <div class="flex justify-center mb-6">
        <img src="/logo-bbw-mark.png" alt="BBW Berufsbildungsschule Winterthur" class="logo-black h-20 w-auto" />
      </div>
      <h1 class="text-xl font-semibold text-center mb-1">Konto erstellen</h1>
      <p class="text-sm text-slate-500 text-center mb-6">Materialplattform · BBW</p>

      <div class="mb-5 p-3 bg-[var(--brand-tint)] border border-[var(--brand)]/30 rounded text-sm text-slate-700">
        <p class="font-medium text-[var(--brand-dark)] mb-1">Registrierung auf Einladung</p>
        <p>Diese Plattform ist nur auf Einladung zugänglich. Für einen Einladungscode wende dich bitte an
          <a href="mailto:pietro.rossi@bbw.ch?subject=Zugang%20Materialplattform" class="font-medium underline" style="color: var(--brand-dark)">pietro.rossi@bbw.ch</a>.
        </p>
      </div>

      {error && (
        <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded text-sm text-red-700">{decodeURIComponent(error)}</div>
      )}
      {success && (
        <div class="mb-4 p-3 bg-emerald-50 border border-emerald-200 rounded text-sm text-emerald-700">{decodeURIComponent(success)}</div>
      )}

      <form method="POST" action="/api/auth/register" class="space-y-4">
        <div>
          <label class="field-label" for="full_name">Name <span class="text-red-500">*</span></label>
          <input id="full_name" name="full_name" type="text" required autocomplete="name" class="input mt-1" placeholder="Vorname Nachname" />
        </div>
        <div>
          <label class="field-label" for="abteilung">Abteilung <span class="text-red-500">*</span></label>
          <select id="abteilung" name="abteilung" required class="input mt-1">
            <option value="">— wählen —</option>
            <option>Bau</option>
            <option>Maschinenbau</option>
            <option>Informatik | Naturwissenschaften</option>
            <option>Technik | Ernährung</option>
          </select>
        </div>
        <div>
          <label class="field-label" for="email">E-Mail <span class="text-red-500">*</span></label>
          <input id="email" name="email" type="email" required autocomplete="email" class="input mt-1" placeholder="vorname.nachname@bbw.ch" />
        </div>
        <div>
          <label class="field-label" for="password">Passwort <span class="text-red-500">*</span></label>
          <input id="password" name="password" type="password" required minlength="8" autocomplete="new-password" class="input mt-1" />
          <div class="text-xs text-slate-400 mt-1">Mindestens 8 Zeichen.</div>
        </div>
        <div>
          <label class="field-label" for="code">Einladungscode <span class="text-red-500">*</span></label>
          <input id="code" name="code" type="text" required autocomplete="off" class="input mt-1" placeholder="Einladungscode eingeben" />
          <div class="text-xs text-slate-400 mt-1">Erhältst du von der ABU-Fachschaft (BBW).</div>
        </div>
        <button type="submit" class="w-full py-2.5 rounded-md text-white font-medium text-sm transition hover:opacity-90" style="background: var(--brand)">
          Registrieren
        </button>
      </form>

      <p class="text-center text-sm text-slate-500 mt-5">
        Bereits angemeldet?
        <a href="/login" class="hover:underline font-medium" style="color: var(--brand)">Anmelden</a>
      </p>
    </div>
  </div>
</Base>
