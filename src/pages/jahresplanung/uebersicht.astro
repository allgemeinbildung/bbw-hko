---
import Base from '../../layouts/Base.astro'
import GuestPrintBlock from '../../components/GuestPrintBlock.astro'
import { nrlp, getNrlp } from '../../lib/nrlp'
import { skFullName } from '../../lib/sk-labels'
import { themesForYear, lehrjahreOf, defaultSchuljahr, parseLehrgang, lehrgangLabel as fmtLehrgang, ALL_LEHRGAENGE, buildKnPlan, type Lehrgang } from '../../lib/jahresplanung/calendar'

const user = Astro.locals.user
if (!user) return Astro.redirect('/login')

const { data: prof } = await Astro.locals.supabase
  .from('profiles').select('role').eq('id', user.id).single()
const isGuest = prof?.role === 'gast'

// ── Slice: nur Lehrgang wählbar (Gesamtansicht über alle Lehrjahre) ──────
const COHORT_ANCHOR = 2025
const _url = new URL(Astro.request.url)
const lehrgang: Lehrgang = parseLehrgang(_url.searchParams.get('lehrgang'))
const lehrgangLabel = fmtLehrgang(lehrgang)
const ds = getNrlp(lehrgang) ?? nrlp
const nYears = lehrjahreOf(lehrgang)

function lbLektionen(lb: any): number { return Number(lb.lektionen) || 0 }
function themaLektionen(t: any): number {
  const fromLb = ((t.lebensbezuege ?? []) as any[]).reduce((s, lb) => s + lbLektionen(lb), 0)
  return fromLb || Number(t.lektionen) || 0
}

// ── Idee 2: Mehrjahres-Bird's-eye — pro Lehrjahr die Themen als Blöcke ────
type YearCol = {
  lehrjahr: number
  schuljahr: string
  total: number
  themas: {
    nr: number; pos: number; titel: string; lektionen: number; isSA: boolean
    lbs: { nr: string; text: string; lektionen: number; kompCount: number }[]
  }[]
}
const years: YearCol[] = []
for (let lj = 1; lj <= nYears; lj++) {
  const themes = themesForYear(ds, lj)
  const themas = themes.map((t, i) => {
    const lbs = ((t.lebensbezuege ?? []) as any[]).map((lb) => ({
      nr: lb.nr, text: lb.text ?? '', lektionen: lbLektionen(lb),
      kompCount: ((lb.kompetenzen ?? []) as any[]).length,
    }))
    return { nr: t.nr, pos: i + 1, titel: t.titel, lektionen: themaLektionen(t), isSA: lbs.length === 0, lbs }
  })
  years.push({
    lehrjahr: lj,
    schuljahr: defaultSchuljahr(COHORT_ANCHOR, lj),
    total: themas.reduce((s, t) => s + t.lektionen, 0),
    themas,
  })
}
const programLektionen = years.reduce((s, y) => s + y.total, 0)
const maxThemaLek = Math.max(1, ...years.flatMap((y) => y.themas.map((t) => t.lektionen)))

// ── Idee 3: Längsschnitt SK-Spirale — 12 SK × alle Themen, nach Lehrjahr ──
const allThemes = ((ds.themen ?? []) as any[]).slice().sort((a, b) => a.nr - b.nr)
const themeCols = allThemes.map((t) => ({ nr: t.nr, lehrjahr: Number(t.lehrjahr), key: 'T' + t.nr }))
const zSk = ((ds as any).zirkularitaet?.schluesselkompetenzen ?? []) as any[]
const spiral = zSk.map((sk, i) => {
  const cells = themeCols.map((c) => (sk.wiederholungen?.[c.key] ?? null) as string | null)
  const stops = cells.filter(Boolean).length
  return { nr: i + 1, name: sk.bezeichnung as string, full: skFullName[sk.bezeichnung] || sk.bezeichnung, cells, stops }
})
// Lehrjahr-Gruppen für die Spalten-Kopfzeile (colspans)
const yearGroups: { lehrjahr: number; span: number }[] = []
for (const c of themeCols) {
  const last = yearGroups[yearGroups.length - 1]
  if (last && last.lehrjahr === c.lehrjahr) last.span++
  else yearGroups.push({ lehrjahr: c.lehrjahr, span: 1 })
}
const neverCovered = spiral.filter((s) => s.stops === 0)

// ── Beispiel-KN-Planung pro Semester (Showcase) — identische Logik wie der Planer ──
const knByYear = years.map((y) => ({
  lehrjahr: y.lehrjahr,
  schuljahr: y.schuljahr,
  plan: buildKnPlan(ds, lehrgang, y.lehrjahr, y.schuljahr),
}))

// ── Idee 4: KN-/Schlussarbeit-Progression ────────────────────────────────
// Semesterbasiert (≥ 3 KN pro Semester) — konsistent mit der Beispielplanung
// unten; das Schlussarbeits-Semester bildet den integrativen Abschluss-Knoten.
type KnNode = { semester: number; themeNrs: number[]; isSA: boolean; count: number }
const knArc = knByYear.map((y) => ({
  lehrjahr: y.lehrjahr,
  schuljahr: y.schuljahr,
  nodes: y.plan.semesters.map((sem) => ({
    semester: sem.semester,
    themeNrs: sem.themeNrs,
    isSA: sem.isSA,
    count: y.plan.seed.filter((k) => k.semester === sem.semester).length,
  } as KnNode)),
}))
const totalKn = knArc.reduce((s, y) => s + y.nodes.reduce((a, n) => a + (n.isSA ? 0 : n.count), 0), 0)

const themaColors = ['cell-thema1', 'cell-thema2', 'cell-thema3']
function posColor(pos: number) { return themaColors[(pos - 1) % themaColors.length] }
---
<Base title={`Gesamtübersicht ${nYears} Jahre · ${lehrgangLabel}`}>
  {isGuest && <GuestPrintBlock />}
  <div class="min-h-screen flex flex-col">
    <header class="bg-white border-b border-slate-200 sticky top-0 z-30">
      <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between gap-4">
        <a href="/" class="flex items-center gap-3 min-w-0">
          <img src="/logo-bbw-mark.png" alt="BBW Berufsbildungsschule Winterthur" class="logo-black h-14 w-auto shrink-0" />
          <span class="hidden md:block pl-3 ml-1 border-l border-slate-200 text-xs uppercase tracking-wider text-slate-500 leading-tight">
            Materialplattform<br />
            <span class="normal-case tracking-normal text-slate-400">ABU Reform 2030</span>
          </span>
        </a>
        <div class="flex items-center gap-4">
          <a href="/nrlp" class="text-sm text-slate-600 hover:text-[var(--brand)] font-medium" title="Vernetzung & Zirkularität der ABU-Inhalte">🕸 nRLP-Netzwerk</a>
          <a href="/jahresplanung" class="text-sm text-slate-600 hover:text-slate-900 font-medium">← Wochenplanung</a>
          <span class="text-sm text-slate-500 hidden sm:block">{user.email}</span>
        </div>
      </div>
    </header>

    <main class="flex-1 max-w-7xl mx-auto w-full px-6 py-10" x-data="uebersicht()" x-cloak>
      <div class="mb-6 flex flex-wrap items-start justify-between gap-4">
        <div>
          <p class="text-xs uppercase tracking-wider text-slate-500 mb-2">Jahresplanung · Gesamtcurriculum · nRLP Bildungsrat 2026</p>
          <h1 class="text-3xl font-semibold text-slate-900 tracking-tight">Das ganze {lehrgangLabel}-Curriculum auf einen Blick</h1>
          <p class="text-slate-600 mt-3 max-w-3xl">
            {nYears} Lehrjahre · {allThemes.length} Themen · {programLektionen} Lektionen geplant.
            Die Spirale zeigt, wann jede Schlüsselkompetenz eingeführt und vertieft wird.
            Klicke auf ein Lehrjahr, um in die Wochenplanung einzusteigen.
          </p>
        </div>
      </div>

      <!-- Lehrgang-Umschalter -->
      <div class="jp-switch mb-8">
        <div class="jp-seg">
          <span class="jp-seg-label">Lehrgang</span>
          {ALL_LEHRGAENGE.map((lg) => (
            <a href={`/jahresplanung/uebersicht?lehrgang=${lg.value}`} class={`jp-pill ${lehrgang === lg.value ? 'jp-pill-on' : ''}`}>{lg.label}</a>
          ))}
        </div>
        <a href="/jahresplanung" class="jp-overview-link">Zur Wochenplanung →</a>
        <div class="jp-pop" @click.outside="moreOpen=false" @keydown.escape="moreOpen=false">
          <button type="button" class="jp-icon" @click="moreOpen=!moreOpen" :aria-expanded="moreOpen" aria-haspopup="menu" aria-label="Weitere Aktionen" title="Weitere Aktionen">⋯</button>
          <div class="jp-menu jp-menu-end" x-show="moreOpen" x-cloak x-transition.opacity.duration.120ms role="menu">
            <button type="button" class="jp-menu-item" role="menuitem" @click="moreOpen=false; printAll()">🖨 Curriculum drucken (A4 quer)</button>
            <button type="button" class="jp-menu-item" role="menuitem" @click="moreOpen=false; exportImage()">⬇ Als Bild exportieren</button>
          </div>
        </div>
      </div>

      <!-- ── Idee 2: Mehrjahres-Übersicht (Curriculum-Landkarte) ───────── -->
      <section class="mb-12" id="ueb-curriculum">
        <h2 class="text-lg font-semibold text-slate-900 mb-1">Curriculum über {nYears} Lehrjahre</h2>
        <p class="text-sm text-slate-500 mb-5">Jede Spalte ein Lehrjahr; Blockhöhe ∝ Lektionen. Klick öffnet die Wochenplanung.</p>
        <div class="ueb-grid" style={`grid-template-columns: repeat(${nYears}, minmax(0,1fr));`}>
          {years.map((y) => (
            <div class="ueb-col">
              <a href={`/jahresplanung?lehrgang=${lehrgang}&lj=${y.lehrjahr}`} class="ueb-col-head">
                <span class="ueb-col-lj">{y.lehrjahr}. Lehrjahr</span>
                <span class="ueb-col-sj">{y.schuljahr} · {y.total} L.</span>
              </a>
              <div class="ueb-blocks">
                {y.themas.map((t) => (
                  <a
                    href={`/jahresplanung/thema/${t.nr}?lehrgang=${lehrgang}`}
                    class={`ueb-block ${posColor(t.pos)} ${t.isSA ? 'ueb-block-sa' : ''}`}
                    style={`min-height:${Math.round(46 + (t.lektionen / maxThemaLek) * 120)}px;`}
                    title={t.titel}
                  >
                    <span class="ueb-block-nr">T{t.nr}{t.isSA ? ' · Schlussarbeit' : ''}</span>
                    <span class="ueb-block-titel">{t.titel}</span>
                    <span class="ueb-block-meta">
                      {t.lektionen} L.{!t.isSA && ` · ${t.lbs.length} Lebensbezüge`}
                      {!t.isSA && <span class="ueb-block-kn">KN</span>}
                    </span>
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- ── Vertiefen-Umschalter: höchstens eine Analyse gleichzeitig ──── -->
      <div class="ueb-deepen" id="ueb-analyses">
        <span class="ueb-deepen-label">Vertiefen</span>
        <button type="button" class="ueb-chip" :class="analysis==='spirale' && 'ueb-chip-on'" @click="toggle('spirale')" :aria-pressed="analysis==='spirale'"><span aria-hidden="true">◷</span> SK-Spirale</button>
        <button type="button" class="ueb-chip" :class="analysis==='arc' && 'ueb-chip-on'" @click="toggle('arc')" :aria-pressed="analysis==='arc'"><span aria-hidden="true">★</span> Kompetenznachweis-Bogen</button>
        <button type="button" class="ueb-chip" :class="analysis==='beispiel' && 'ueb-chip-on'" @click="toggle('beispiel')" :aria-pressed="analysis==='beispiel'"><span aria-hidden="true">▣</span> KN-Beispielplanung</button>
      </div>
      <p class="ueb-hint" x-show="!analysis" x-cloak>Wähle eine Analyse, um tiefer einzutauchen — sie erscheint hier darunter.</p>

      <!-- ── Idee 3: Längsschnitt SK-Spirale ───────────────────────────── -->
      <section class="ueb-analysis mb-12" x-show="analysis==='spirale'" x-cloak x-transition.opacity.duration.150ms>
        <h2 class="text-lg font-semibold text-slate-900 mb-1">Schlüsselkompetenz-Spirale</h2>
        <p class="text-sm text-slate-500 mb-5">
          Wann wird jede der 12 SK über die {nYears} Jahre eingeführt (R1), wiederaufgenommen (R2) und vertieft (R3)?
          Leere Zeilen = im ganzen Bildungsgang nicht systematisch verankert.
        </p>
        <div class="overflow-x-auto">
          <table class="spiral">
            <thead>
              <tr>
                <th class="sp-name-h" rowspan="2">Schlüsselkompetenz</th>
                {yearGroups.map((g) => (
                  <th class="sp-year-h" colspan={g.span}>{g.lehrjahr}. Lehrjahr</th>
                ))}
                <th class="sp-stops-h" rowspan="2">Stationen</th>
              </tr>
              <tr>
                {themeCols.map((c) => <th class="sp-th-h">T{c.nr}</th>)}
              </tr>
            </thead>
            <tbody>
              {spiral.map((sk) => (
                <tr class={sk.stops === 0 ? 'sp-row-off' : ''}>
                  <td class="sp-name" title={sk.full}><span class="sp-nr">{sk.nr}</span>{sk.name}</td>
                  {sk.cells.map((c) => (
                    <td class={`sp-cell ${c ? `sp-r${String(c).replace('R', '')}` : 'sp-empty'}`}>{c || ''}</td>
                  ))}
                  <td class={`sp-stops ${sk.stops === 0 ? 'sp-stops-zero' : ''}`}>{sk.stops}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <div class="flex flex-wrap items-center gap-x-5 gap-y-2 mt-4 text-xs text-slate-500">
          <span class="flex items-center gap-1.5"><span class="sp-swatch sp-r1"></span>R1 — Einführung</span>
          <span class="flex items-center gap-1.5"><span class="sp-swatch sp-r2"></span>R2 — Wiederaufnahme</span>
          <span class="flex items-center gap-1.5"><span class="sp-swatch sp-r3"></span>R3 — Vertiefung</span>
          {neverCovered.length > 0 && (
            <span class="text-amber-600 font-medium ml-auto">
              {neverCovered.length} SK ohne feste Verankerung: {neverCovered.map((s) => s.name).join(', ')}
            </span>
          )}
        </div>
      </section>

      <!-- ── Idee 4: KN-/Schlussarbeit-Progression ─────────────────────── -->
      <section class="ueb-analysis mb-8" x-show="analysis==='arc'" x-cloak x-transition.opacity.duration.150ms>
        <h2 class="text-lg font-semibold text-slate-900 mb-1">Kompetenznachweise & Schlussarbeit</h2>
        <p class="text-sm text-slate-500 mb-5">
          {totalKn} Kompetenznachweise (mind. 3 pro Semester → 3 Noten Gesellschaft + 3 Noten Sprache)
          bauen über die Jahre auf die Schlussarbeit hin.
        </p>
        <div class="kn-arc">
          {knArc.map((y, yi) => (
            <div class="kn-year">
              <div class="kn-year-head">
                <span class="kn-year-lj">{y.lehrjahr}. LJ</span>
                <span class="kn-year-sj">{y.schuljahr}</span>
              </div>
              <div class="kn-nodes">
                {y.nodes.map((node) => (
                  <div class={`kn-node ${node.isSA ? 'kn-node-sa' : ''}`}>
                    <span class="kn-node-badge">{node.isSA ? '★ Schlussarbeit' : `Sem ${node.semester} · ${node.count} KN`}</span>
                    <span class="kn-node-titel">
                      {node.isSA
                        ? 'Integrativer Kompetenznachweis · Prozess · Produkt · Präsentation'
                        : `${node.count} Noten Gesellschaft + ${node.count} Noten Sprache`}
                    </span>
                    <span class="kn-node-meta">Themen {node.themeNrs.map((n) => 'T' + n).join(', ')}</span>
                  </div>
                ))}
              </div>
              {yi < knArc.length - 1 && <div class="kn-arrow">→</div>}
            </div>
          ))}
        </div>
      </section>

      <!-- ── Beispiel: KN-Planung pro Semester (Showcase) ──────────────── -->
      <section class="ueb-analysis mb-8" x-show="analysis==='beispiel'" x-cloak x-transition.opacity.duration.150ms>
        <h2 class="text-lg font-semibold text-slate-900 mb-1">Beispiel-KN-Planung pro Semester</h2>
        <p class="text-sm text-slate-500 mb-5">
          Pro Semester mind. 3 Kompetenznachweise → 3 Noten Gesellschaft + 3 Noten Sprache.
          Je KN ein Vorschlag: Sprachmodus (Sprache-Note) · gesellschaftlicher Aspekt (Ges-Note) · Schlüsselkompetenz.
          Im Planer pro Klasse anpassbar.
        </p>
        <div class="space-y-5">
          {knByYear.map((y) => (
            <div class="knex-year">
              <div class="knex-year-head">
                <span class="knex-year-lj">{y.lehrjahr}. Lehrjahr</span>
                <span class="knex-year-sj">{y.schuljahr}</span>
              </div>
              <div class="knex-sems">
                {y.plan.semesters.map((sem) => {
                  const slots = y.plan.seed.filter((k) => k.semester === sem.semester)
                  return (
                    <div class="knex-sem">
                      <div class="knex-sem-head">
                        <span>Semester {sem.semester} · {sem.themeNrs.map((n) => 'T' + n).join(', ')}</span>
                        <span class="knex-sem-tag">{sem.isSA ? 'Schlussarbeit · integrativ' : `${slots.length} KN · 3+3 Noten`}</span>
                      </div>
                      <div class="knex-kns">
                        {slots.map((kn, i) => (
                          <div class="knex-kn">
                            <span class="knex-kn-nr">KN {i + 1}</span>
                            {kn.sprachmodus && <span class="knex-tag knex-tag-spr" title="Sprache-Note">{kn.sprachmodus}</span>}
                            {kn.aspekt && <span class="knex-tag knex-tag-ges" title="Gesellschaft-Note">{kn.aspekt}</span>}
                            {kn.sk && <span class="knex-tag knex-tag-sk" title="Schlüsselkompetenz">{kn.sk}</span>}
                            {sem.isSA && <span class="knex-tag knex-tag-ges">Prozess · Produkt · Präsentation</span>}
                          </div>
                        ))}
                      </div>
                    </div>
                  )
                })}
              </div>
            </div>
          ))}
        </div>
      </section>
    </main>

    <footer class="border-t border-slate-200 py-4 px-6 text-center text-xs text-slate-400">
      Gesamtübersicht · nRLP {lehrgangLabel} · ABU Reform 2030 — Bildungsrat 2026
    </footer>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js" is:inline></script>
  <script is:inline>
    function uebersicht() {
      return {
        analysis: null,
        moreOpen: false,
        toggle(a) { this.analysis = this.analysis === a ? null : a },
        printAll() { window.print() },
        exportImage() {
          const el = document.getElementById('ueb-curriculum')
          if (!el || typeof html2canvas === 'undefined') { window.print(); return }
          html2canvas(el, { backgroundColor: '#ffffff', scale: 2 }).then((canvas) => {
            const a = document.createElement('a')
            a.href = canvas.toDataURL('image/png')
            a.download = 'Curriculum-Uebersicht.png'
            a.click()
          }).catch(() => window.print())
        },
      }
    }
  </script>

  <style>
    [x-cloak] { display: none !important; }
    /* Slice-Switcher (geteilt mit /jahresplanung) */
    .jp-switch { display: flex; flex-wrap: wrap; align-items: center; gap: 0.6rem 1rem; background: white; border: 1px solid #e2e8f0; border-radius: 0.5rem; padding: 0.6rem 0.9rem; }
    .jp-seg { display: flex; align-items: center; gap: 0.4rem; }
    .jp-seg-label { font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; }
    .jp-pill { display: inline-flex; align-items: center; font-size: 0.78rem; font-weight: 600; color: #334155; text-decoration: none; border: 1px solid #cbd5e1; border-radius: 9999px; padding: 0.28rem 0.7rem; transition: all .15s; }
    .jp-pill:hover { border-color: var(--brand); color: var(--brand-dark); }
    .jp-pill-on { background: var(--brand); color: white; border-color: var(--brand); }
    .jp-pill-on:hover { color: white; }
    .jp-overview-link { margin-left: auto; font-size: 0.8rem; font-weight: 700; color: var(--brand-dark); text-decoration: none; border-bottom: 2px solid transparent; padding-bottom: 1px; }
    .jp-overview-link:hover { border-bottom-color: var(--brand); }

    /* ⋯ Overflow-Menü (geteilt mit /jahresplanung) */
    .jp-pop { position: relative; }
    .jp-icon { display: inline-flex; align-items: center; justify-content: center; width: 38px; height: 38px; border-radius: 8px; border: 1px solid #cbd5e1; background: white; color: #475569; font-size: 1.1rem; font-weight: 700; line-height: 1; transition: border-color .15s, color .15s; }
    .jp-icon:hover { border-color: var(--brand); color: var(--brand-dark); }
    .jp-menu { position: absolute; top: calc(100% + 6px); left: 0; z-index: 50; min-width: 16rem; background: white; border: 1px solid #e2e8f0; border-radius: 10px; padding: 0.35rem; box-shadow: 0 18px 40px -18px rgba(15,23,42,0.35), 0 0 0 1px rgba(14,110,58,0.06); }
    .jp-menu-end { left: auto; right: 0; }
    .jp-menu-item { display: flex; align-items: center; width: 100%; text-align: left; gap: 0.5rem; font-size: 0.82rem; font-weight: 600; color: #334155; background: transparent; border: none; border-radius: 7px; padding: 0.5rem 0.6rem; cursor: pointer; transition: background .12s, color .12s; }
    .jp-menu-item:hover { background: var(--brand-tint); color: var(--brand-dark); }

    /* Vertiefen-Umschalter */
    .ueb-deepen { display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem; background: white; border: 1px solid #e2e8f0; border-radius: 0.5rem; padding: 0.6rem 0.8rem; margin-bottom: 0.75rem; }
    .ueb-deepen-label { font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; margin-right: 0.25rem; }
    .ueb-chip { display: inline-flex; align-items: center; gap: 0.35rem; font-size: 0.8rem; font-weight: 600; color: #334155; background: #f8fafc; border: 1px solid #cbd5e1; border-radius: 9999px; padding: 0.35rem 0.85rem; min-height: 40px; cursor: pointer; transition: all .15s; }
    .ueb-chip:hover { border-color: var(--brand); color: var(--brand-dark); }
    .ueb-chip-on { background: var(--brand); color: white; border-color: var(--brand); }
    .ueb-chip-on:hover { color: white; }
    .ueb-hint { font-size: 0.82rem; color: #94a3b8; font-style: italic; padding: 0.75rem 0.2rem 0.25rem; margin-bottom: 1.5rem; }

    /* Idee 2: Bird's-eye */
    .ueb-grid { display: grid; gap: 0.9rem; }
    .ueb-col { display: flex; flex-direction: column; gap: 0.6rem; }
    .ueb-col-head { display: flex; flex-direction: column; text-decoration: none; padding: 0.5rem 0.7rem; border-radius: 8px; background: #f8fafc; border: 1px solid #e2e8f0; transition: border-color .15s; }
    .ueb-col-head:hover { border-color: var(--brand); }
    .ueb-col-lj { font-size: 0.85rem; font-weight: 700; color: #0f172a; }
