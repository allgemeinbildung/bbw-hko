---
import Base from '../../../layouts/Base.astro'
import GuestPrintBlock from '../../../components/GuestPrintBlock.astro'
import { nrlp, getNrlp } from '../../../lib/nrlp'
import { situationenIndex } from '../../../lib/situationen'
import einheitenIndex from '../../../data/einheiten.index.json'
import { themesForYear, parseLehrgang, lehrgangLabel as fmtLehrgang, type Lehrgang } from '../../../lib/jahresplanung/calendar'

const user = Astro.locals.user
if (!user) return Astro.redirect('/login')
const { data: prof } = await Astro.locals.supabase
  .from('profiles').select('role').eq('id', user.id).single()
const isGuest = prof?.role === 'gast'

const _url = new URL(Astro.request.url)
const lehrgang: Lehrgang = parseLehrgang(_url.searchParams.get('lehrgang'))
const lehrgangLabel = fmtLehrgang(lehrgang)
const ds = getNrlp(lehrgang) ?? nrlp

const nr = parseInt(Astro.params.nr ?? '', 10)
const theme = ((ds.themen ?? []) as any[]).find((t) => Number(t.nr) === nr)
if (!theme) return Astro.redirect(`/jahresplanung/uebersicht?lehrgang=${lehrgang}`)

const lehrjahr = Number(theme.lehrjahr)
const yearThemes = themesForYear(ds, lehrjahr)
const posIdx = yearThemes.findIndex((t) => Number(t.nr) === nr)
const pos = posIdx + 1
const lbs = (theme.lebensbezuege ?? []) as any[]
const isSA = lbs.length === 0
const themaLektionen = lbs.reduce((s, lb) => s + (Number(lb.lektionen) || 0), 0) || Number(theme.lektionen) || 0
const leitidee = theme.leitidee ?? {}
const themeSK = (theme.schluesselkompetenzen ?? []) as string[]
const themeSM = (theme.sprachmodi ?? []) as string[]

// Vorheriges / nächstes Thema im selben Lehrjahr (Navigation)
const prevTheme = posIdx > 0 ? yearThemes[posIdx - 1] : null
const nextTheme = posIdx < yearThemes.length - 1 ? yearThemes[posIdx + 1] : null

// ── Verknüpftes Material: Herausforderungen (Einheiten) + Situationen ────
const lbCodes = new Set(lbs.map((lb) => lb.nr))
const hfByLb: Record<string, any[]> = {}
for (const e of einheitenIndex as any[]) {
  if (!lbCodes.has(e.modul)) continue
  ;(hfByLb[e.modul] ??= []).push({
    id: e.id, titel: e.titel, kompetenz_nr: e.kompetenz_nr,
    hat_kn: Boolean(e.hat_kn), hat_begleiter: Boolean(e.hat_begleiter),
    sit_count: (e.situationen ?? []).length,
  })
}
const sitByLb: Record<string, any[]> = {}
for (const s of situationenIndex) {
  if (!s.lebensbezug_nr || !lbCodes.has(s.lebensbezug_nr)) continue
  ;(sitByLb[s.lebensbezug_nr] ??= []).push({
    id: s.id, titel: s.titel ?? s.id, letter: s.sit_letter ?? '',
  })
}
for (const k of Object.keys(sitByLb)) sitByLb[k].sort((a, b) => (a.letter || '').localeCompare(b.letter || ''))

const wochenHref = `/jahresplanung?lehrgang=${lehrgang}&lj=${lehrjahr}`
const themaHref = (n: number) => `/jahresplanung/thema/${n}?lehrgang=${lehrgang}`
---
<Base title={`Thema ${nr} — ${theme.titel}`}>
  {isGuest && <GuestPrintBlock />}
  <div class="min-h-screen flex flex-col">
    <header class="bg-white border-b border-slate-200 sticky top-0 z-30">
      <div class="max-w-5xl mx-auto px-6 py-3 flex items-center justify-between gap-4">
        <a href="/" class="flex items-center gap-3 min-w-0">
          <img src="/logo-bbw-mark.png" alt="BBW Berufsbildungsschule Winterthur" class="logo-black h-14 w-auto shrink-0" />
          <span class="hidden md:block pl-3 ml-1 border-l border-slate-200 text-xs uppercase tracking-wider text-slate-500 leading-tight">
            Materialplattform<br />
            <span class="normal-case tracking-normal text-slate-400">ABU Reform 2030</span>
          </span>
        </a>
        <div class="flex items-center gap-4">
          <a href={`/jahresplanung/uebersicht?lehrgang=${lehrgang}`} class="text-sm text-slate-600 hover:text-slate-900 font-medium">← Gesamtübersicht</a>
          <span class="text-sm text-slate-500 hidden sm:block">{user.email}</span>
        </div>
      </div>
    </header>

    <main class="flex-1 max-w-5xl mx-auto w-full px-6 py-10" x-data={`themaDetail(${JSON.stringify(lbs.map((l: any) => l.nr))})`} x-cloak data-lehrgang={getNrlp(lehrgang) ? lehrgang : 'EFZ-3J'}>
      <!-- Hero -->
      <div class="thd-hero thema-top" data-thema={nr}>
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <p class="thd-kicker">{lehrgangLabel} · {lehrjahr}. Lehrjahr{isSA ? ' · Schlussarbeit' : ''}</p>
            <h1 class="thd-title">Thema {nr} — {theme.titel}</h1>
            <div class="thd-meta">
              <span class="thd-chip">{themaLektionen} Lektionen</span>
              {!isSA && <span class="thd-chip">{lbs.length} Lebensbezüge</span>}
              {!isSA && <span class="thd-chip">{lbs.reduce((s, lb) => s + ((lb.kompetenzen ?? []).length), 0)} Kompetenzen</span>}
            </div>
          </div>
          <a href={wochenHref} class="thd-cta">Zur Wochenplanung →</a>
        </div>
      </div>

      <!-- Leitidee — Kurztext immer sichtbar, Langtext gefaltet -->
      {(leitidee.kurz || leitidee.detail) && (
        <section class="thd-card mb-6">
          <h2 class="thd-h2">Leitidee</h2>
          {leitidee.kurz && <p class="text-slate-800 leading-relaxed">{leitidee.kurz}</p>}
          {leitidee.detail && (
            <button type="button" class="thd-more-btn" @click="leitidee=!leitidee" :aria-expanded="leitidee">
              <span class="thd-more-caret" x-text="leitidee ? '▾' : '▸'"></span> Ausführliche Leitidee
            </button>
          )}
          {leitidee.detail && (
            <p class="text-sm text-slate-600 leading-relaxed mt-3" x-show="leitidee" x-cloak>{leitidee.detail}</p>
          )}
        </section>
      )}

      <!-- Thema-Taxonomie: SK + Sprachmodi -->
      {(themeSK.length > 0 || themeSM.length > 0) && (
        <section class="grid md:grid-cols-2 gap-4 mb-8">
          {themeSK.length > 0 && (
            <div class="thd-card">
              <h2 class="thd-h2">Schlüsselkompetenzen</h2>
              <ul class="space-y-1.5">
                {themeSK.map((sk) => <li class="text-sm text-slate-700 flex gap-2"><span class="thd-dot"></span>{sk}</li>)}
              </ul>
            </div>
          )}
          {themeSM.length > 0 && (
            <div class="thd-card">
              <h2 class="thd-h2">Sprachmodi</h2>
              <div class="flex flex-wrap gap-1.5">
                {themeSM.map((sm) => <span class="thd-sm-chip">{sm}</span>)}
              </div>
            </div>
          )}
        </section>
      )}

      <!-- Schlussarbeit-Spezialfall -->
      {isSA && (
        <section class="thd-card mb-8">
          <h2 class="thd-h2">Anforderungen</h2>
          <p class="text-sm text-slate-600 leading-relaxed">
            Die Schlussarbeit besteht aus <strong>Prozess, Produkt und Präsentation</strong>, berücksichtigt
            mindestens vier Sprachmodi und deckt mindestens drei Schlüsselkompetenzen ab. Das Thema wird aus
            mindestens zwei gesellschaftlichen Aspekten betrachtet.
          </p>
        </section>
      )}

      <!-- Lebensbezüge als Akkordeon — Material zuerst, nRLP-Taxonomie gefaltet -->
      {!isSA && (
        <section class="mb-8">
          <div class="flex items-baseline justify-between flex-wrap gap-2 mb-4">
            <h2 class="text-lg font-semibold text-slate-900">Lebensbezüge & Kompetenzen</h2>
            <div class="thd-acc-actions text-xs">
              <button type="button" class="thd-acc-link" @click="openAll()">Alle öffnen</button>
              <span class="text-slate-300">·</span>
              <button type="button" class="thd-acc-link" @click="closeAll()">Alle schliessen</button>
            </div>
          </div>
          <div class="space-y-4">
            {lbs.map((lb) => {
              const hfs = hfByLb[lb.nr] ?? []
              const sits = sitByLb[lb.nr] ?? []
              const kompCount = (lb.kompetenzen ?? []).length
              return (
              <div class="thd-lb thema-left" data-thema={nr} :class={`isOpen('${lb.nr}') && 'thd-lb-open'`}>
                <button type="button" class="thd-lb-head thd-lb-toggle" @click={`toggle('${lb.nr}')`} :aria-expanded={`isOpen('${lb.nr}')`}>
                  <span class="thd-lb-nr">{lb.nr}</span>
                  <div class="min-w-0 flex-1">
                    <p class="thd-lb-text">{lb.text}</p>
                    <div class="thd-lb-meta">
                      {lb.lektionen ? <span class="thd-lb-metachip">{lb.lektionen} Lektionen</span> : null}
                      <span class="thd-lb-metachip">{kompCount} {kompCount === 1 ? 'Kompetenz' : 'Kompetenzen'}</span>
                      {hfs.length > 0 && <span class="thd-lb-metachip thd-lb-metachip-mat">{hfs.length} {hfs.length === 1 ? 'Einheit' : 'Einheiten'}</span>}
                      {sits.length > 0 && <span class="thd-lb-metachip">{sits.length} Situationen</span>}
                    </div>
                  </div>
                  <span class="thd-chevron" aria-hidden="true">▾</span>
                </button>

                <div class="thd-lb-body" x-show={`isOpen('${lb.nr}')`} x-cloak x-collapse>
                  <!-- 1) Fertiges Material zuerst, farbig hervorgehoben -->
                  {(hfs.length || sits.length) ? (
                    <div class="thd-mat-box">
                      <p class="thd-mat-box-h">Direkt einsetzbar</p>
                      {hfs.length > 0 && (
                        <div class="mb-3">
                          <p class="thd-mat-h">Herausforderungen (fertige Einheiten)</p>
                          <ul class="space-y-1.5">
                            {hfs.map((hf: any) => (
                              <li>
                                <a href={`/einheiten/${hf.id}`} target="_blank" rel="noopener" class="thd-hf">
                                  <span class="thd-hf-titel">{hf.titel}</span>
                                  <span class="thd-hf-meta">
                                    <span class="thd-hf-komp">{hf.kompetenz_nr}</span>
                                    <span>{hf.sit_count} Situationen</span>
                                    {hf.hat_kn && <span class="thd-hf-badge">KN</span>}
                                    {hf.hat_begleiter && <span class="thd-hf-badge">Begleiter</span>}
                                  </span>
                                </a>
                              </li>
                            ))}
                          </ul>
                        </div>
                      )}
                      {sits.length > 0 && (
                        <div>
                          <p class="thd-mat-h">Situationen zur Inspiration</p>
                          <div class="flex flex-wrap gap-1.5">
                            {sits.slice(0, 8).map((s: any) => (
                              <a href={`/situationen/${s.id}`} target="_blank" rel="noopener" class="thd-sit">
                                <span class="thd-sit-letter">{s.letter}</span>{s.titel}
                              </a>
                            ))}
                          </div>
                          <a href={`/situationen?lebensbezug=${lb.nr}`} target="_blank" rel="noopener" class="thd-sit-all">Alle {sits.length} Situationen durchsuchen →</a>
                        </div>
                      )}
                    </div>
                  ) : (
                    <p class="thd-mat-empty">Noch keine fertige Einheit für diesen Lebensbezug — siehe Kompetenzen unten.</p>
                  )}

                  <!-- 2) Kompetenzen prominent; nRLP-Feingliederung gefaltet -->
                  <div class="space-y-3 mt-4">
                    {(lb.kompetenzen ?? []).map((k: any) => {
                      const hasDetail = (k.gesellschaftliche_inhalte ?? []).length > 0 || (k.sprachmodi ?? []).length > 0
                      return (
                      <div class="thd-komp">
                        <p class="thd-komp-titel"><span class="thd-komp-nr">{k.nr}</span>{k.text}</p>
                        {hasDetail && (
                          <button type="button" class="thd-komp-toggle" @click={`toggleKomp('${k.nr}')`} :aria-expanded={`isKompOpen('${k.nr}')`}>
                            <span class="thd-more-caret" x-text={`isKompOpen('${k.nr}') ? '▾' : '▸'`}>▸</span> nRLP-Details
                          </button>
                        )}
                        {hasDetail && (
                          <div class="thd-komp-detail" x-show={`isKompOpen('${k.nr}')`} x-cloak x-collapse>
                            {(k.gesellschaftliche_inhalte ?? []).length > 0 && (
                              <div class="thd-sub">
                                <p class="thd-sub-h">Gesellschaftliche Inhalte</p>
                                <ul class="space-y-1">
                                  {(k.gesellschaftliche_inhalte ?? []).map((g: any) => (
                                    <li class="text-xs text-slate-600"><span class="thd-aspekt">{g.aspekt}</span>{g.detail}</li>
                                  ))}
                                </ul>
                              </div>
                            )}
                            {(k.sprachmodi ?? []).length > 0 && (
                              <div class="thd-sub">
                                <p class="thd-sub-h">Sprachmodi</p>
                                <ul class="space-y-1">
                                  {(k.sprachmodi ?? []).map((s: any) => (
                                    <li class="text-xs text-slate-600"><span class="thd-modus">{s.modus}</span>{s.detail}</li>
                                  ))}
                                </ul>
                              </div>
                            )}
                          </div>
                        )}
                      </div>
                      )
                    })}
                  </div>
                </div>
              </div>
              )
            })}
          </div>
        </section>
      )}

      <!-- Themen-Navigation innerhalb des Lehrjahrs -->
      <nav class="thd-nav">
        {prevTheme
          ? <a href={themaHref(prevTheme.nr)} class="thd-nav-link">← T{prevTheme.nr} · {prevTheme.titel}</a>
          : <span></span>}
        <a href={wochenHref} class="thd-nav-center">Wochenplanung {lehrjahr}. Lehrjahr</a>
        {nextTheme
          ? <a href={themaHref(nextTheme.nr)} class="thd-nav-link thd-nav-right">T{nextTheme.nr} · {nextTheme.titel} →</a>
          : <span></span>}
      </nav>
    </main>

    <footer class="border-t border-slate-200 py-4 px-6 text-center text-xs text-slate-400">
      Thema {nr} · nRLP {lehrgangLabel} · ABU Reform 2030 — Bildungsrat 2026
    </footer>
  </div>

  <script is:inline>
    function themaDetail(lbNrs) {
      const all = Array.isArray(lbNrs) ? lbNrs.map(String) : []
      return {
        openLb: {}, openKomp: {}, leitidee: false,
        init() { if (all.length) this.openLb[all[0]] = true },
        isOpen(nr) { return !!this.openLb[String(nr)] },
        toggle(nr) { nr = String(nr); this.openLb = { ...this.openLb, [nr]: !this.openLb[nr] } },
        openAll() { const o = {}; all.forEach((n) => (o[n] = true)); this.openLb = o },
        closeAll() { this.openLb = {} },
        isKompOpen(nr) { return !!this.openKomp[String(nr)] },
        toggleKomp(nr) { nr = String(nr); this.openKomp = { ...this.openKomp, [nr]: !this.openKomp[nr] } },
      }
    }
  </script>

  <style>
    [x-cloak] { display: none !important; }
    .thd-hero { border-radius: 0.75rem; padding: 1.5rem 1.75rem; margin-bottom: 1.5rem; border: 1px solid #e2e8f0; border-top: 4px solid var(--brand); }
    .thd-hero[data-thema] { background: color-mix(in srgb, var(--tc) 9%, #fff); }
    .thd-kicker { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--brand-dark); }
    .thd-title { font-size: 1.75rem; font-weight: 700; color: #0f172a; line-height: 1.15; margin-top: 0.25rem; }
    .thd-meta { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.85rem; }
    .thd-chip { font-size: 0.72rem; font-weight: 600; color: var(--brand-dark); background: white; border: 1px solid rgba(14,110,58,0.25); border-radius: 9999px; padding: 0.15rem 0.6rem; }
    .thd-cta { align-self: flex-start; white-space: nowrap; font-size: 0.85rem; font-weight: 700; color: white; background: var(--brand); border-radius: 8px; padding: 0.55rem 1rem; text-decoration: none; transition: background .15s; }
    .thd-cta:hover { background: var(--brand-dark); }

    .thd-card { background: white; border: 1px solid #e2e8f0; border-radius: 0.5rem; padding: 1.25rem 1.5rem; }
    .thd-h2 { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; margin-bottom: 0.75rem; }
    .thd-dot { display: inline-block; width: 0.4rem; height: 0.4rem; border-radius: 9999px; background: var(--brand); margin-top: 0.45rem; flex-shrink: 0; }
    .thd-sm-chip { font-size: 0.72rem; font-weight: 600; color: var(--brand-dark); background: var(--brand-tint); border-radius: 9999px; padding: 0.15rem 0.6rem; }

    .thd-lb { background: white; border: 1px solid #e2e8f0; border-left: 4px solid var(--brand); border-radius: 0.5rem; padding: 0; overflow: hidden; }
    /* Linke Akzentkante = Thema-Farbe (.thema-left + data-thema, global). */
    .thd-lb-toggle {
      display: flex; align-items: flex-start; gap: 0.75rem; width: 100%; text-align: left;
      background: transparent; border: none; cursor: pointer; padding: 1.1rem 1.5rem; transition: background .15s;
    }
    .thd-lb-toggle:hover { background: #f8fafc; }
    .thd-lb-open > .thd-lb-toggle { background: #f8fafc; }
    .thd-lb-nr { flex-shrink: 0; font-size: 0.8rem; font-weight: 800; color: var(--tc-ink, white); background: var(--tc, var(--brand)); border-radius: 6px; padding: 0.2rem 0.5rem; margin-top: 0.1rem; }
    .thd-lb-text { font-size: 0.95rem; font-weight: 600; color: #0f172a; line-height: 1.35; }
    .thd-lb-meta { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.5rem; }
    .thd-lb-metachip { font-size: 0.66rem; font-weight: 600; color: #64748b; background: #f1f5f9; border-radius: 9999px; padding: 0.1rem 0.5rem; }
    .thd-lb-metachip-mat { color: var(--brand-dark); background: var(--brand-tint); }
    .thd-chevron { flex-shrink: 0; align-self: center; color: #94a3b8; font-size: 0.8rem; transition: transform .2s; }
    .thd-lb-open > .thd-lb-toggle .thd-chevron { transform: rotate(180deg); }
    .thd-lb-body { padding: 0 1.5rem 1.4rem; }

    /* Material-Box (zuerst, farbig hervorgehoben) */
    .thd-mat-box { background: var(--brand-tint); border: 1px solid rgba(14,110,58,0.22); border-radius: 10px; padding: 0.85rem 1rem; }
    .thd-mat-box-h { font-size: 0.6rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em; color: var(--brand-dark); margin-bottom: 0.55rem; }
    .thd-mat-empty { font-size: 0.78rem; font-style: italic; color: #94a3b8; border-left: 2px solid #e2e8f0; padding-left: 0.6rem; }

    /* Kompetenz-Detail-Toggle (nRLP gefaltet) */
    .thd-komp-toggle {
      display: inline-flex; align-items: center; gap: 0.35rem; margin-top: 0.5rem;
      font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em;
      color: #64748b; background: transparent; border: none; cursor: pointer; padding: 0.15rem 0;
    }
    .thd-komp-toggle:hover { color: var(--brand-dark); }
    .thd-komp-detail { margin-top: 0.3rem; }
    .thd-more-caret { display: inline-block; width: 0.7rem; color: #94a3b8; }

    /* Leitidee-Mehr + Akkordeon-Aktionen */
    .thd-more-btn {
      display: inline-flex; align-items: center; gap: 0.4rem; margin-top: 0.75rem;
      font-size: 0.78rem; font-weight: 600; color: var(--brand-dark);
      background: transparent; border: none; cursor: pointer; padding: 0;
    }
    .thd-more-btn:hover { text-decoration: underline; }
    .thd-acc-link { font-weight: 600; color: var(--brand-dark); background: transparent; border: none; cursor: pointer; padding: 0 0.2rem; }
    .thd-acc-link:hover { text-decoration: underline; }

    .thd-komp { border: 1px solid #f1f5f9; border-radius: 8px; padding: 0.75rem 0.9rem; background: #f8fafc; }
    .thd-komp-titel { font-size: 0.85rem; color: #1e293b; line-height: 1.35; }
    .thd-komp-nr { display: inline-block; font-weight: 800; color: var(--brand-dark); margin-right: 0.4rem; }
    .thd-sub { margin-top: 0.6rem; }
    .thd-sub-h { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: #94a3b8; margin-bottom: 0.25rem; }
    .thd-aspekt { display: inline-block; font-weight: 700; color: var(--brand-dark); margin-right: 0.35rem; }
    .thd-modus { display: inline-block; font-weight: 700; color: #475569; margin-right: 0.35rem; }

    .thd-material { margin-top: 1rem; padding-top: 1rem; border-top: 1px dashed #e2e8f0; }
    .thd-mat-h { font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: var(--brand-dark); margin-bottom: 0.4rem; }
    .thd-hf { display: block; text-decoration: none; border: 1px solid rgba(14,110,58,0.18); border-radius: 6px; padding: 0.45rem 0.6rem; background: var(--brand-tint); transition: border-color .15s, box-shadow .15s; }
    .thd-hf:hover { border-color: var(--brand); box-shadow: 0 4px 12px -6px rgba(14,110,58,0.4); }
    .thd-hf-titel { display: block; font-size: 0.78rem; font-weight: 600; color: #0f172a; }
    .thd-hf-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 0.3rem 0.45rem; font-size: 0.62rem; color: #64748b; margin-top: 0.2rem; }
    .thd-hf-komp { font-weight: 700; color: var(--brand-dark); background: white; border-radius: 4px; padding: 0 0.3rem; }
    .thd-hf-badge { font-size: 0.55rem; font-weight: 800; text-transform: uppercase; color: var(--brand-dark); border: 1px solid rgba(14,110,58,0.3); border-radius: 9999px; padding: 0 0.3rem; }
    .thd-sit { display: inline-flex; align-items: center; gap: 0.35rem; font-size: 0.72rem; color: #334155; text-decoration: none; border: 1px solid #e2e8f0; border-radius: 6px; padding: 0.2rem 0.5rem; }
