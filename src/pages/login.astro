---
import Base from '../layouts/Base.astro'

if (Astro.locals.user) return Astro.redirect('/')

const error = Astro.url.searchParams.get('error')
---
<Base title="Anmelden">
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-sm bg-white border border-slate-200 rounded-xl p-8 shadow-sm">

      <div class="flex justify-center mb-6">
        <img src="/logo-bbw-mark.png" alt="BBW Berufsbildungsschule Winterthur" class="logo-black h-20 w-auto" />
      </div>
      <h1 class="text-xl font-semibold text-center mb-1">Anmelden</h1>
      <p class="text-sm text-slate-500 text-center mb-6">ABU-Materialplattform · BBW</p>

      {error && (
        <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded text-sm text-red-700">{decodeURIComponent(error)}</div>
      )}

      <div class="mb-4 p-3 bg-[var(--brand-tint)] border border-[var(--brand)]/30 rounded text-sm text-slate-700">
        <p class="font-medium text-[var(--brand-dark)] mb-1">Lehrpersonen der BBW</p>
        <p>Bitte mit dem <strong>BBW-Microsoft-Konto</strong> anmelden (Button unten).</p>
      </div>

      <!-- Microsoft / BBW login -->
      <a
        href="/api/auth/microsoft"
        class="flex items-center justify-center gap-3 w-full py-2.5 rounded-md border border-slate-300 bg-white text-sm font-medium text-slate-700 hover:bg-slate-50 transition mb-5"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 22 22" width="18" height="18" aria-hidden="true">
          <rect x="0"  y="0"  width="10" height="10" fill="#f25022"/>
          <rect x="12" y="0"  width="10" height="10" fill="#7fba00"/>
          <rect x="0"  y="12" width="10" height="10" fill="#00a4ef"/>
          <rect x="12" y="12" width="10" height="10" fill="#ffb900"/>
        </svg>
        Mit Microsoft (BBW) anmelden
      </a>

      <div class="flex items-center gap-3 mb-5">
        <hr class="flex-1 border-slate-200">
        <span class="text-xs text-slate-400">oder mit E-Mail</span>
        <hr class="flex-1 border-slate-200">
      </div>

      <form method="POST" action="/api/auth/login" class="space-y-4">
        <div>
          <label class="field-label" for="email">E-Mail</label>
          <input id="email" name="email" type="email" required autocomplete="email" class="input mt-1" placeholder="vorname.nachname@bbw.ch" />
        </div>
        <div>
          <label class="field-label" for="password">Passwort</label>
          <input id="password" name="password" type="password" required autocomplete="current-password" class="input mt-1" />
        </div>
        <button type="submit" class="w-full py-2.5 rounded-md text-white font-medium text-sm transition hover:opacity-90" style="background: var(--brand)">
          Anmelden
        </button>
      </form>

      <div class="flex items-center gap-3 my-5">
        <hr class="flex-1 border-slate-200">
        <span class="text-xs text-slate-400">noch kein Konto?</span>
        <hr class="flex-1 border-slate-200">
      </div>

      <a
        href="/registrieren"
        class="flex items-center justify-center w-full py-2.5 rounded-md border border-slate-300 bg-white text-sm font-medium text-slate-700 hover:bg-slate-50 transition"
      >
        Konto erstellen
      </a>
      <p class="text-center text-xs text-slate-400 mt-2">
        Registrierung nur auf Einladung (Einladungscode erforderlich).
      </p>
      <p class="text-center text-xs text-slate-400 mt-3">
        Nur schauen? <a href="/welcome" class="hover:underline" style="color: var(--brand)">Gast-Zugang &rarr;</a>
      </p>
    </div>
  </div>
</Base>
