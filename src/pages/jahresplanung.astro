        <div class="stat-card stat-accent"><p class="stat-label">Unterricht</p><p class="stat-value">90 L.</p></div>
        <div class="stat-card"><p class="stat-label">Puffer</p><p class="stat-value">27 L.</p></div>
        <div class="stat-card"><p class="stat-label">Ferienwochen</p><p class="stat-value">8</p></div>
      </div>

      <!-- Legend -->
      <div class="bg-white border border-slate-200 rounded-lg p-4 mb-6 flex flex-wrap items-center gap-x-6 gap-y-3 text-xs">
