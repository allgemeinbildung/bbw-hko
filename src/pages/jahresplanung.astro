  <script id="nrlp-lookup" type="application/json" set:html={JSON.stringify(lookup)} />
  <script id="jp-calendar" type="application/json" set:html={JSON.stringify(calendar)} />
  <script id="jp-situationen" type="application/json" set:html={JSON.stringify(sitByLb)} />
  <script id="jp-herausforderungen" type="application/json" set:html={JSON.stringify(hfByLb)} />
  <script id="jp-thema-sk" type="application/json" set:html={JSON.stringify(themaSK)} />
  <script id="jp-sk-names" type="application/json" set:html={JSON.stringify(skMatrix.map((s) => ({ nr: s.nr, name: s.name, full: s.full })))} />
