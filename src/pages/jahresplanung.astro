          @mouseenter="cancelHide()"
          @mouseleave="hide()"
        >
          <template x-if="active">
            <div>
              <div class="flex items-start justify-between gap-3 mb-1.5">
                <div>
                  <p class="text-[10px] uppercase tracking-wider text-slate-400" x-text="`KW ${active.kw} · ${active.datum}`"></p>
                  <p class="text-sm font-semibold text-slate-900" x-text="merged(active.n).title"></p>
                </div>
                <span class="tip-badge" :class="cellClass(merged(active.n))" x-text="merged(active.n).type === 'holiday' ? 'Frei' : (merged(active.n).type === 'buffer' ? 'Puffer' : 'T' + active.thema)"></span>
              </div>
              <p class="text-xs text-slate-500 mb-3" x-text="`${active.lessons} ${active.lessons === 1 ? 'Lektion' : 'Lektionen'}` + (active.note ? ' · ' + active.note : '')"></p>

              <!-- Feature 4: Inline-Editor -->
              <template x-if="editing">
                <div class="jp-tip-edit">
                  <p class="text-[10px] uppercase tracking-wider text-slate-400 mb-1.5">Woche bearbeiten</p>
                  <div class="flex gap-2 mb-2">
                    <button class="jp-mini" :class="merged(active.n).type==='teaching' && 'jp-mini-on'" x-on:click="setCellType(active.n,'teaching')">Unterricht</button>
                    <button class="jp-mini" :class="merged(active.n).type==='buffer' && 'jp-mini-on'" x-on:click="setCellType(active.n,'buffer')">Puffer</button>
                  </div>
                  <input type="text" class="jp-input w-full mb-2" :value="merged(active.n).title" x-on:input="setCellTitle(active.n,$event.target.value)" placeholder="Titel der Woche" />
                  <div class="flex justify-between items-center">
                    <button class="text-xs text-slate-400 hover:text-slate-700" x-on:click="resetCell(active.n)">↺ zurücksetzen</button>
                    <button class="text-xs text-[var(--brand-dark)] font-semibold" x-on:click="closeEditor()">Fertig</button>
                  </div>
                </div>
              </template>

              <template x-if="active.lb && lookup[active.lb]">
                <div class="border-t border-slate-200 pt-3">
                  <p class="text-[10px] uppercase tracking-wider text-slate-400 mb-0.5">Lebensbezug <span x-text="active.lb"></span></p>
                  <p class="text-xs text-slate-700 italic mb-3" x-text="lookup[active.lb].lebensbezug_text"></p>

                  <!-- Herausforderungen (zentral) -->
                  <template x-if="hfFor(active.lb).length">
                    <div class="jp-hf-box mb-3">
                      <p class="jp-hf-h">Herausforderungen · <span x-text="hfFor(active.lb).length"></span></p>
                      <ul class="space-y-2">
                        <template x-for="hf in hfFor(active.lb)" :key="hf.id">
                          <li>
                            <a :href="`/einheiten/${hf.id}`" target="_blank" rel="noopener" class="jp-hf-link">
                              <span class="jp-hf-titel" x-text="hf.titel"></span>
                              <span class="jp-hf-meta">
                                <span class="jp-hf-kompetenz" x-text="hf.kompetenz_nr"></span>
                                <span x-text="hf.sit_count + ' Situationen'"></span>
                                <template x-if="hf.hat_kn"><span class="jp-hf-badge">KN</span></template>
                                <template x-if="hf.hat_begleiter"><span class="jp-hf-badge">Begleiter</span></template>
                                <span class="jp-hf-cta">Zur Herausforderung →</span>
                              </span>
                            </a>
                          </li>
                        </template>
                      </ul>
                    </div>
                  </template>
                  <template x-if="!hfFor(active.lb).length">
                    <p class="jp-hf-empty mb-3">Noch keine fertige Herausforderung für diesen Lebensbezug — Situationen unten dienen als Inspiration.</p>
                  </template>

