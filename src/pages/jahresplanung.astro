  <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js" is:inline></script>

  <script is:inline>
    function jahresplanung() {
      const parse = (id) => JSON.parse(document.getElementById(id).textContent)
      const base = parse('jp-calendar')
      const baseByN = Object.fromEntries(base.map((c) => [c.n, c]))
      return {
        // ── static data ──
        lookup: parse('nrlp-lookup'),
        calendar: base,
        baseByN,
        sitByLb: parse('jp-situationen'),
        hfByLb: parse('jp-herausforderungen'),
        themaSK: parse('jp-thema-sk'),
        skNames: parse('jp-sk-names'),
        plans: parse('jp-plans'),

        // ── tooltip state ──
        active: null, tipX: 0, tipY: 0, hideTimer: null, pinned: false, editing: false,

        // ── panel toggles ──
        editMode: false, showKn: false, showCoverage: false,

        // ── plan instance state (Feature 4/6/8) ──
        activePlanId: null,
        overrides: {},
        knPlans: [],
        coverage: {},
        saving: false, dirty: false, savedAt: null, saveTimer: null,

        init() {
          if (this.plans.length) this.loadPlan(this.plans[0])
          else this.knPlans = this.defaultKn()
        },

        // ── merged (base + overrides) ──
        merged(n) { return { ...this.baseByN[n], ...(this.overrides[n] || {}) } },
        mtype(n) {
          const m = this.merged(n)
          if (m.type === 'holiday') return 'holiday'
          if (m.type === 'buffer') return 'buffer'
          if (m.thema === 1) return 'thema1'
          if (m.thema === 2) return 'thema2'
          if (m.thema === 3) return 'thema3'
          return 'buffer'
        },
        mLessons(n) { const l = this.merged(n).lessons; return l > 0 ? l + ' L.' : '–' },
        mTitleMark(n) { const m = this.merged(n); return m.lb ? m.lb : (m.type === 'holiday' ? '★' : '·') },
        cellClass(w) {
          if (!w) return ''
          if (w.type === 'holiday') return 'cell-holiday'
          if (w.type === 'buffer') return 'cell-buffer'
          if (w.thema === 1) return 'cell-thema1'
          if (w.thema === 2) return 'cell-thema2'
          if (w.thema === 3) return 'cell-thema3'
          return 'cell-buffer'
        },

        // ── Herausforderungen (zentral) ──
        hfFor(lb) { return this.hfByLb[lb] || [] },
        hfCount(n) { const lb = this.merged(n).lb; return lb ? (this.hfByLb[lb] || []).length : 0 },

        // ── Situationen (Inspiration, sekundär) ──
        sitFor(lb) { return this.sitByLb[lb] || [] },
        sitCount(n) { const lb = this.merged(n).lb; return lb ? (this.sitByLb[lb] || []).length : 0 },

        // ── Feature 6: KN ──
        defaultKn() {
          return [
            { id: 'kn1', label: 'KN 1 · Thema 1 — Einstieg', week_n: null, format: '', notes: '' },
            { id: 'kn2', label: 'KN 2 · Thema 2 — Meinung bilden', week_n: null, format: '', notes: '' },
            { id: 'kn3', label: 'KN 3 · Thema 3 — Konsum', week_n: null, format: '', notes: '' },
          ]
        },
        hasKn(n) { return this.knPlans.some((k) => Number(k.week_n) === n) },
        teachingWeeks() { return this.calendar.filter((c) => this.merged(c.n).type === 'teaching') },

        // ── tooltip ──
        show(n, ev) {
          this.cancelHide()
          const w = this.calendar.find((c) => c.n === n)
          if (!w) return
          const rect = ev.currentTarget.getBoundingClientRect()
          const containerRect = ev.currentTarget.closest('section').getBoundingClientRect()
          const tooltipWidth = 340
          let x = rect.left - containerRect.left + rect.width / 2 - tooltipWidth / 2
          x = Math.max(8, Math.min(x, containerRect.width - tooltipWidth - 8))
          const y = rect.bottom - containerRect.top + 10
          this.tipX = x; this.tipY = y; this.active = w
        },
        hide() { if (this.pinned) return; this.hideTimer = setTimeout(() => { this.active = null }, 120) },
        cancelHide() { if (this.hideTimer) { clearTimeout(this.hideTimer); this.hideTimer = null } },

        // ── Feature 4: editing ──
        onCellClick(n, ev) {
          if (this.editMode && this.mtype(n) !== 'holiday') this.openEditor(n, ev)
          else this.show(n, ev)
        },
        openEditor(n, ev) { this.show(n, ev); this.editing = true; this.pinned = true },
        closeEditor() { this.editing = false; this.pinned = false; this.active = null },
        setCellType(n, type) {
          const ov = { ...(this.overrides[n] || {}), type }
          if (type === 'teaching' && this.baseByN[n].thema == null) ov.thema = this.baseByN[n].thema
          this.overrides = { ...this.overrides, [n]: ov }
          this.markDirty()
        },
        setCellTitle(n, val) {
          this.overrides = { ...this.overrides, [n]: { ...(this.overrides[n] || {}), title: val } }
          this.markDirty()
        },
        resetCell(n) {
          const o = { ...this.overrides }; delete o[n]; this.overrides = o; this.markDirty()
        },

        // ── Feature 8: coverage ──
        taughtLbs() {
          const seen = []
          for (const c of this.calendar) {
            const m = this.merged(c.n)
            if (m.type === 'teaching' && m.lb && !seen.includes(m.lb)) seen.push(m.lb)
          }
          return seen
        },
        recSk(lb) { const info = this.lookup[lb]; return info ? (this.themaSK[info.thema_nr] || []) : [] },
        recSm(lb) { const info = this.lookup[lb]; return info ? (info.sprachmodi || []) : [] },
        covKey(kind) { return kind === 'sk' ? 'sk_done' : 'sprachmodus_done' },
        isDone(lb, kind, name) {
          const c = this.coverage[lb]; if (!c) return false
          return (c[this.covKey(kind)] || []).includes(name)
        },
        toggle(lb, kind, name) {
          const key = this.covKey(kind)
          const c = { sk_done: [], sprachmodus_done: [], ...(this.coverage[lb] || {}) }
          const arr = [...(c[key] || [])]
          const i = arr.indexOf(name)
          if (i >= 0) arr.splice(i, 1); else arr.push(name)
          c[key] = arr
          this.coverage = { ...this.coverage, [lb]: c }
          this.markDirty()
        },
        skSummary() {
          return this.skNames.map((sk) => {
            let count = 0
            for (const lb in this.coverage) {
              if ((this.coverage[lb].sk_done || []).includes(sk.name)) count++
            }
            return { name: sk.name, full: sk.full, count }
          })
        },

        // ── persistence ──
        markDirty() { this.dirty = true; this.savedAt = null; this.scheduleSave() },
        scheduleSave() {
          if (!this.activePlanId) return
          if (this.saveTimer) clearTimeout(this.saveTimer)
          this.saveTimer = setTimeout(() => this.save(), 2000)
        },
        async save() {
          if (!this.activePlanId) return
          this.saving = true
          try {
            const res = await fetch('/api/jahresplan/' + this.activePlanId, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                calendar_overrides: this.overrides,
                kn_plans: this.knPlans,
                coverage: this.coverage,
              }),
            })
            if (!res.ok) throw new Error((await res.json()).error || 'Fehler')
            this.dirty = false; this.savedAt = Date.now()
          } catch (e) {
            alert('Speichern fehlgeschlagen: ' + e.message)
          } finally {
            this.saving = false
          }
        },
        loadPlan(p) {
          this.activePlanId = p.id
          this.overrides = p.calendar_overrides || {}
          this.knPlans = (p.kn_plans && p.kn_plans.length) ? p.kn_plans : this.defaultKn()
          this.coverage = p.coverage || {}
          this.dirty = false; this.savedAt = null
        },
        switchPlan(id) {
          const p = this.plans.find((x) => x.id === id)
          if (p) this.loadPlan(p)
        },
        async newPlan() {
          const label = prompt('Name der Klassen-Planung (z.B. 26EFZ-A):')
          if (!label) return
          this.saving = true
          try {
            const res = await fetch('/api/jahresplan', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ label }),
            })
            const json = await res.json()
            if (!res.ok) throw new Error(json.error || 'Fehler')
            this.plans = [...this.plans, json.data]
            this.loadPlan(json.data)
          } catch (e) {
            alert('Anlegen fehlgeschlagen: ' + e.message + '\n(Migration 011 angewendet?)')
          } finally {
            this.saving = false
          }
        },

        // ── Feature 7: Excel export ──
        exportExcel() {
          if (typeof XLSX === 'undefined') { alert('Excel-Bibliothek noch nicht geladen.'); return }
          const rows = [['KW', 'Datum', 'Thema', 'Typ', 'Titel', 'Lektionen', 'Lebensbezug', 'Herausforderungen', 'Kompetenzen', 'Schlüsselkompetenzen', 'Sprachmodi', 'Notizen']]
          const typLabel = { teaching: 'Unterricht', buffer: 'Puffer', holiday: 'Ferien' }
          for (const c of this.calendar) {
            const m = this.merged(c.n)
            if (m.type === 'holiday') continue
            const info = m.lb ? this.lookup[m.lb] : null
            const komp = info ? info.kompetenzen.map((k) => k.nr + ' ' + k.text).join('\n') : ''
            const hf = m.lb ? (this.hfByLb[m.lb] || []).map((h) => h.kompetenz_nr + ' · ' + h.titel).join('\n') : ''
            const sk = m.thema ? (this.themaSK[m.thema] || []).join(', ') : ''
            const sm = info ? (info.sprachmodi || []).join(', ') : ''
            rows.push([
              'KW ' + m.kw, m.datum, m.thema ? 'T' + m.thema : '', typLabel[m.type] || m.type,
              m.title, m.lessons, m.lb || '', hf, komp, sk, sm, m.note || '',
            ])
          }
          const ws = XLSX.utils.aoa_to_sheet(rows)
          ws['!cols'] = [{ wch: 7 }, { wch: 16 }, { wch: 6 }, { wch: 11 }, { wch: 34 }, { wch: 8 }, { wch: 11 }, { wch: 48 }, { wch: 50 }, { wch: 34 }, { wch: 30 }, { wch: 24 }]
          const wb = XLSX.utils.book_new()
          const label = this.activePlanId ? (this.plans.find((p) => p.id === this.activePlanId)?.label || 'Plan') : 'Basisvorlage'
          XLSX.utils.book_append_sheet(wb, ws, 'Jahresplanung')
          XLSX.writeFile(wb, 'Jahresplanung_1LJ_' + label.replace(/[^\w-]+/g, '_') + '.xlsx')
        },
      }
    }
  </script>

