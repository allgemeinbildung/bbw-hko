              ))}
            </div>
          ))}
        </div>
        <div class="flex flex-wrap items-center gap-x-5 gap-y-2 mt-4 text-xs text-slate-500">
          <span class="flex items-center gap-1.5"><span class="sk-swatch sk-r1"></span>R1 — erste Begegnung</span>
          <span class="flex items-center gap-1.5"><span class="sk-swatch sk-r2"></span>R2 — Wiederaufnahme</span>
          <span class="flex items-center gap-1.5"><span class="sk-swatch sk-r3"></span>R3 — Vertiefung</span>
          <span class="flex items-center gap-1.5"><span class="sk-swatch sk-empty"></span>nicht im 1. Lehrjahr</span>
        </div>
      </section>

      <!-- Feature 3: Feiertags- / Notizen-Panel -->
      <details class="jp-notes mb-8" open>
        <summary>
          <span class="font-semibold text-slate-800">Feiertage, Brückentage &amp; didaktische Hinweise</span>
          <span class="text-xs text-slate-400 ml-2">{noteWeeks.length} Wochen mit Vermerk</span>
        </summary>
        <div class="grid md:grid-cols-2 gap-6 mt-4">
          <div>
            <p class="jp-notes-h">Feiertage &amp; Brückentage</p>
            {feiertagNotes.length ? (
              <ul class="space-y-1.5">
                {feiertagNotes.map((w) => (
                  <li class="flex items-baseline gap-2 text-sm">
                    <span class="jp-note-kw">KW {w.kw}</span>
                    <span class="text-slate-400 text-xs w-28 shrink-0">{w.datum}</span>
                    <span class="text-slate-700">{w.note}</span>
                  </li>
                ))}
              </ul>
            ) : <p class="text-sm text-slate-400 italic">Keine.</p>}
          </div>
          <div>
            <p class="jp-notes-h">Didaktische Hinweise (KN / Prüfungen)</p>
            {didaktikNotes.length ? (
              <ul class="space-y-1.5">
                {didaktikNotes.map((w) => (
                  <li class="flex items-baseline gap-2 text-sm">
                    <span class="jp-note-kw">KW {w.kw}</span>
                    <span class="text-slate-400 text-xs w-28 shrink-0">{w.datum}</span>
                    <span class="text-slate-700">{w.note}</span>
                  </li>
                ))}
              </ul>
            ) : <p class="text-sm text-slate-400 italic">Keine.</p>}
          </div>
        </div>
        <p class="text-xs text-slate-400 mt-3 italic">
          Hinweis: Alle Schulwochen zählen 3 Lektionen — auch Wochen mit Feiertag.
          Der Vermerk macht nur sichtbar, wo mit reduzierter Präsenz zu rechnen ist.
        </p>
      </details>

      <!-- Feature 6: KN-Planungs-Sidebar -->
      <section x-show="showKn" x-cloak class="jp-panel mb-8">
        <div class="flex items-baseline justify-between flex-wrap gap-2 mb-1">
          <h2 class="text-lg font-semibold text-slate-900">Kompetenznachweise planen</h2>
          <span class="text-xs text-slate-400">Termin · Format · Vorbereitung — pro Klasse gespeichert</span>
        </div>
        <p class="text-sm text-slate-600 mb-4" x-show="!plans.length">
          Lege zuerst oben eine <strong>Klasse</strong> an, um KN-Termine zu speichern.
        </p>
        <div class="space-y-3" x-show="plans.length">
          <template x-for="kn in knPlans" :key="kn.id">
            <div class="jp-kn-row">
              <div class="jp-kn-title" x-text="kn.label"></div>
              <label class="jp-field">
                <span>Woche</span>
                <select x-model.number="kn.week_n" x-on:change="markDirty()" class="jp-select">
                  <option :value="null">—</option>
                  <template x-for="w in teachingWeeks()" :key="w.n">
                    <option :value="w.n" x-text="`KW ${w.kw} · ${w.datum}`"></option>
                  </template>
                </select>
              </label>
              <label class="jp-field">
                <span>Format</span>
                <select x-model="kn.format" x-on:change="markDirty()" class="jp-select">
                  <option value="">—</option>
                  {KN_TYP_OPTIONS.map((o) => <option value={o.value}>{o.label}</option>)}
                </select>
              </label>
              <label class="jp-field jp-field-grow">
                <span>Notizen / vorbereitende Situationen</span>
                <input type="text" x-model="kn.notes" x-on:input="markDirty()" class="jp-input" placeholder="z.B. Sit. 1.1_A + 1.1_B, Konfliktrollenspiel" />
              </label>
            </div>
          </template>
        </div>
      </section>

      <!-- Feature 8: Abdeckungs-Tab (SK + Sprachmodi, live) -->
      <section x-show="showCoverage" x-cloak class="jp-panel mb-8">
        <div class="flex items-baseline justify-between flex-wrap gap-2 mb-1">
          <h2 class="text-lg font-semibold text-slate-900">Abdeckung — was wurde tatsächlich geübt?</h2>
          <span class="text-xs text-slate-400">Pro Lebensbezug abhaken · Vergleich mit nRLP-Empfehlung</span>
        </div>
        <p class="text-sm text-slate-600 mb-4" x-show="!plans.length">
          Lege zuerst oben eine <strong>Klasse</strong> an, um die Abdeckung zu erfassen.
        </p>
        <div x-show="plans.length">
          <!-- Live SK summary -->
          <div class="mb-5">
            <p class="jp-notes-h mb-2">SK-Abdeckung (abgehakt × · grau = nicht geübt)</p>
            <div class="flex flex-wrap gap-2">
              <template x-for="sk in skSummary()" :key="sk.name">
                <span class="jp-sk-chip" :class="sk.count ? 'jp-sk-chip-on' : 'jp-sk-chip-off'" :title="sk.full">
                  <span x-text="sk.name"></span>
                  <span class="jp-sk-count" x-text="sk.count + '×'"></span>
                </span>
              </template>
            </div>
          </div>
          <!-- Per-Lebensbezug checklists -->
          <div class="space-y-4">
            <template x-for="lb in taughtLbs()" :key="lb">
              <div class="jp-cov-block">
                <p class="jp-cov-h">
                  <span x-text="lb"></span> ·
                  <span class="text-slate-500 font-normal" x-text="lookup[lb] ? lookup[lb].thema_titel : ''"></span>
                </p>
                <div class="grid md:grid-cols-2 gap-x-6 gap-y-3 mt-2">
                  <div>
                    <p class="jp-cov-sub">Schlüsselkompetenzen (nRLP T<span x-text="lookup[lb] ? lookup[lb].thema_nr : ''"></span>)</p>
                    <template x-for="skName in recSk(lb)" :key="skName">
                      <label class="jp-check">
                        <input type="checkbox" :checked="isDone(lb,'sk',skName)" x-on:change="toggle(lb,'sk',skName)" />
