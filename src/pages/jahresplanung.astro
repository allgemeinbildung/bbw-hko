---
import Base from '../layouts/Base.astro'
import GuestPrintBlock from '../components/GuestPrintBlock.astro'
import { nrlp } from '../lib/nrlp'
import { situationenIndex } from '../lib/situationen'
import einheitenIndex from '../data/einheiten.index.json'
import { skFullName } from '../lib/sk-labels'
import { KN_TYP_OPTIONS } from '../lib/einheiten/kn-typ-labels'

const user = Astro.locals.user
if (!user) return Astro.redirect('/login')

const { data: jpProfile } = await Astro.locals.supabase
  .from('profiles')
  .select('role')
  .eq('id', user.id)
  .single()
const isGuest = jpProfile?.role === 'gast'

// Build a flat lookup { "1.1": { thema, titel, kompetenzen[], sprachmodi[] }, ... }
type KompetenzInfo = { nr: string; text: string }
type LebensbezugInfo = {
  thema_nr: number
  thema_titel: string
  lebensbezug_nr: string
  lebensbezug_text: string
  lektionen: number | null
  kompetenzen: KompetenzInfo[]
  sprachmodi: string[]
}
const lookup: Record<string, LebensbezugInfo> = {}
for (const thema of nrlp.themen as any[]) {
  for (const lb of (thema.lebensbezuege ?? []) as any[]) {
    // Union of Sprachmodi recommended across this Lebensbezug's Kompetenzen
    const sm = new Set<string>()
    for (const k of (lb.kompetenzen ?? []) as any[]) {
      for (const s of (k.sprachmodi ?? []) as any[]) if (s?.modus) sm.add(s.modus)
    }
    lookup[lb.nr] = {
      thema_nr: thema.nr,
      thema_titel: thema.titel,
      lebensbezug_nr: lb.nr,
      lebensbezug_text: lb.text,
      lektionen: lb.lektionen ?? null,
      kompetenzen: (lb.kompetenzen ?? []).map((k: any) => ({ nr: k.nr, text: k.text })),
      sprachmodi: [...sm],
    }
  }
}

// ── Feature 5: Situationen-Empfehlungen — grouped by Lebensbezug ──────────
type SitRef = { id: string; titel: string; letter: string; format: string | null }
const sitByLb: Record<string, SitRef[]> = {}
for (const s of situationenIndex) {
  if (!s.lebensbezug_nr) continue
  ;(sitByLb[s.lebensbezug_nr] ??= []).push({
    id: s.id,
    titel: s.titel ?? s.id,
    letter: s.sit_letter ?? '',
    format: s.handlungsprodukt_format,
  })
}
for (const k of Object.keys(sitByLb)) {
  sitByLb[k].sort((a, b) => (a.letter || '').localeCompare(b.letter || ''))
}

// ── Herausforderungen (Einheiten) — central material, grouped by Lebensbezug ──
// An Einheit's `modul` field (e.g. "1.1") equals the calendar's `lb` code.
// These are the live, ready-to-teach units (Situationen above are inspiration).
type HfRef = {
  id: string
  titel: string
  kompetenz_nr: string
  hat_kn: boolean
  hat_begleiter: boolean
  sit_count: number
}
const hfByLb: Record<string, HfRef[]> = {}
for (const e of einheitenIndex as any[]) {
  const lb = e.modul as string
  if (!lb) continue
  ;(hfByLb[lb] ??= []).push({
    id: e.id,
    titel: e.titel,
    kompetenz_nr: e.kompetenz_nr,
    hat_kn: Boolean(e.hat_kn),
    hat_begleiter: Boolean(e.hat_begleiter),
    sit_count: (e.situationen ?? []).length,
  })
}

// ── Feature 1: SK-Abdeckungsmatrix (canonical nRLP) ──────────────────────
// Source: zirkularitaet.schluesselkompetenzen[].wiederholungen — the official
// "which SK is scheduled in which Thema" map. Columns = T1/T2/T3 (1. Lehrjahr),
// cell = iteration depth R1/R2/R3 (light→dark), empty = not covered this year.
const SK_COLS = ['T1', 'T2', 'T3'] as const
const zSk = ((nrlp as any).zirkularitaet?.schluesselkompetenzen ?? []) as any[]
const skMatrix = zSk.map((sk, i) => ({
  nr: i + 1,
  name: sk.bezeichnung as string,
  full: skFullName[sk.bezeichnung] || sk.bezeichnung,
  cells: SK_COLS.map((t) => (sk.wiederholungen?.[t] ?? null) as string | null),
  inYear: SK_COLS.some((t) => Boolean(sk.wiederholungen?.[t])),
}))
// Thema → recommended SK names (for the Excel "SKs" column + coverage checklist)
const themaSK: Record<number, string[]> = { 1: [], 2: [], 3: [] }
zSk.forEach((sk) => {
  ;([1, 2, 3] as const).forEach((t) => {
    if (sk.wiederholungen?.['T' + t]) themaSK[t].push(sk.bezeichnung)
  })
})
// Sprachmodi zirkularitaet (for the live coverage tab, Feature 8)
const zSm = ((nrlp as any).zirkularitaet?.sprachmodi ?? []) as any[]
const smCanon = zSm.map((s) => s.bezeichnung as string)

// School calendar — derived from JAHRESPLANUNG_1Lehrjahr_2025-2026.md
// week: ISO week label, n: lesson-week ordinal (1..40)
// trimester: T1|T2|T3, type: teaching|buffer|holiday, thema: 1|2|3|null
// lb: lebensbezug code (matches lookup keys above) — optional for non-teaching
type CellType = 'teaching' | 'buffer' | 'holiday'
type WeekCell = {
  n: number
  kw: number
  datum: string
  month: string
  trimester: 'T1' | 'T2' | 'T3'
  thema: 1 | 2 | 3 | null
  lessons: number
  type: CellType
  title: string
  lb?: string
  note?: string
}

const calendar: WeekCell[] = [
  // ─── THEMA 1 — Aug 18 – Nov 7 (12 weeks incl. Herbstferien) ──────────
  { n: 1, kw: 34, datum: '18.–22. Aug', month: 'August', trimester: 'T1', thema: 1, lessons: 3, type: 'teaching', title: 'T1.1 Einstieg & Lehrvertrag', lb: '1.1' },
  { n: 2, kw: 35, datum: '25.–29. Aug', month: 'August', trimester: 'T1', thema: 1, lessons: 3, type: 'teaching', title: 'T1.1 Rechte & Pflichten', lb: '1.1' },
  { n: 3, kw: 36, datum: '1.–5. Sep', month: 'September', trimester: 'T1', thema: 1, lessons: 3, type: 'teaching', title: 'T1.1 IT-Werkzeuge', lb: '1.1' },
  { n: 4, kw: 37, datum: '8.–12. Sep', month: 'September', trimester: 'T1', thema: 1, lessons: 3, type: 'teaching', title: 'T1.1 Kommunikation', lb: '1.1' },
  { n: 5, kw: 38, datum: '15.–19. Sep', month: 'September', trimester: 'T1', thema: 1, lessons: 3, type: 'teaching', title: 'T1.1 Konfliktgespräch', lb: '1.1', note: 'Vorbereitung KN 1.1' },
  { n: 6, kw: 39, datum: '22.–26. Sep', month: 'September', trimester: 'T1', thema: 1, lessons: 3, type: 'teaching', title: 'T1.2 Lernorganisation', lb: '1.2' },
  { n: 7, kw: 40, datum: '29. Sep – 3. Okt', month: 'Oktober', trimester: 'T1', thema: 1, lessons: 3, type: 'teaching', title: 'T1.2 Ressourcen & KN-Vorbereitung', lb: '1.2' },
  { n: 8, kw: 41, datum: '6.–10. Okt', month: 'Oktober', trimester: 'T1', thema: null, lessons: 0, type: 'holiday', title: 'Herbstferien' },
  { n: 9, kw: 42, datum: '13.–17. Okt', month: 'Oktober', trimester: 'T1', thema: null, lessons: 0, type: 'holiday', title: 'Herbstferien' },
  { n: 10, kw: 43, datum: '20.–24. Okt', month: 'Oktober', trimester: 'T1', thema: 1, lessons: 3, type: 'teaching', title: 'KN 1.1 Konfliktgespräch', note: 'Kompetenznachweis 1.1' },
  { n: 11, kw: 44, datum: '27.–31. Okt', month: 'Oktober', trimester: 'T1', thema: 1, lessons: 3, type: 'buffer', title: 'T1 Repetition & Vertiefung' },
  { n: 12, kw: 45, datum: '3.–7. Nov', month: 'November', trimester: 'T1', thema: 1, lessons: 3, type: 'buffer', title: 'T1 Puffer — Abschluss' },

  // ─── THEMA 2 — Nov 10 – Mär 13 (18 weeks incl. Weihnachts- + Sportferien) ──
  { n: 13, kw: 46, datum: '10.–14. Nov', month: 'November', trimester: 'T2', thema: 2, lessons: 3, type: 'teaching', title: 'T2.1 Quellen kritisch prüfen', lb: '2.1' },
  { n: 14, kw: 47, datum: '17.–21. Nov', month: 'November', trimester: 'T2', thema: 2, lessons: 3, type: 'teaching', title: 'T2.1 Manipulation & Desinformation', lb: '2.1' },
  { n: 15, kw: 48, datum: '24.–28. Nov', month: 'November', trimester: 'T2', thema: 2, lessons: 3, type: 'teaching', title: 'T2.1 Filterblasen & Algorithmen', lb: '2.1' },
  { n: 16, kw: 49, datum: '1.–5. Dez', month: 'Dezember', trimester: 'T2', thema: 2, lessons: 3, type: 'teaching', title: 'T2.2 Diskriminierung', lb: '2.2' },
  { n: 17, kw: 50, datum: '8.–12. Dez', month: 'Dezember', trimester: 'T2', thema: 2, lessons: 3, type: 'teaching', title: 'T2.2 Meinungsfreiheit', lb: '2.2', note: 'Prüfung Desinformation' },
  { n: 18, kw: 51, datum: '15.–19. Dez', month: 'Dezember', trimester: 'T2', thema: 2, lessons: 3, type: 'teaching', title: 'T2.2 Standpunkte entwickeln', lb: '2.2' },
  { n: 19, kw: 52, datum: '22.–26. Dez', month: 'Dezember', trimester: 'T2', thema: null, lessons: 0, type: 'holiday', title: 'Weihnachtsferien' },
  { n: 20, kw: 1, datum: '29. Dez – 2. Jan', month: 'Januar', trimester: 'T2', thema: null, lessons: 0, type: 'holiday', title: 'Weihnachtsferien' },
  { n: 21, kw: 2, datum: '5.–9. Jan', month: 'Januar', trimester: 'T2', thema: 2, lessons: 3, type: 'teaching', title: 'T2.2 Kunst & Haltungen', lb: '2.2' },
  { n: 22, kw: 3, datum: '12.–16. Jan', month: 'Januar', trimester: 'T2', thema: 2, lessons: 3, type: 'teaching', title: 'T2.3 Politische Mitwirkung', lb: '2.3' },
  { n: 23, kw: 4, datum: '19.–23. Jan', month: 'Januar', trimester: 'T2', thema: 2, lessons: 3, type: 'teaching', title: 'T2.3 Anliegen formulieren', lb: '2.3' },
  { n: 24, kw: 5, datum: '26.–30. Jan', month: 'Januar', trimester: 'T2', thema: 2, lessons: 3, type: 'teaching', title: 'T2.3 Debatte & Diskussion', lb: '2.3', note: 'Mündliche Diskussion' },
  { n: 25, kw: 6, datum: '2.–6. Feb', month: 'Februar', trimester: 'T2', thema: null, lessons: 0, type: 'holiday', title: 'Sportferien' },
  { n: 26, kw: 7, datum: '9.–13. Feb', month: 'Februar', trimester: 'T2', thema: null, lessons: 0, type: 'holiday', title: 'Sportferien' },
  { n: 27, kw: 8, datum: '16.–20. Feb', month: 'Februar', trimester: 'T2', thema: 2, lessons: 3, type: 'buffer', title: 'T2 Puffer Repetition' },
  { n: 28, kw: 9, datum: '23.–27. Feb', month: 'Februar', trimester: 'T2', thema: 2, lessons: 3, type: 'buffer', title: 'T2 Puffer Vertiefung', note: 'Fastnachtsmontag frei' },
  { n: 29, kw: 10, datum: '2.–6. Mär', month: 'März', trimester: 'T2', thema: 2, lessons: 3, type: 'buffer', title: 'T2 Puffer Prüfungsvorbereitung' },
  { n: 30, kw: 11, datum: '9.–13. Mär', month: 'März', trimester: 'T2', thema: 2, lessons: 3, type: 'teaching', title: 'T2 Abschluss & Übergabe zu T3' },

  // ─── THEMA 3 — Mär 16 – Jul 10 (17 weeks incl. Frühjahrsferien) ──────
  { n: 31, kw: 12, datum: '16.–20. Mär', month: 'März', trimester: 'T3', thema: 3, lessons: 3, type: 'teaching', title: 'T3.1 Bedürfnisse erkennen', lb: '3.1' },
  { n: 32, kw: 13, datum: '23.–27. Mär', month: 'März', trimester: 'T3', thema: 3, lessons: 3, type: 'teaching', title: 'T3.1 Budget planen', lb: '3.1' },
  { n: 33, kw: 14, datum: '30. Mär – 3. Apr', month: 'April', trimester: 'T3', thema: 3, lessons: 3, type: 'teaching', title: 'T3.1 Verschuldung', lb: '3.1', note: 'Karfreitag frei' },
  { n: 34, kw: 15, datum: '6.–10. Apr', month: 'April', trimester: 'T3', thema: 3, lessons: 3, type: 'teaching', title: 'T3.1 Abschluss', lb: '3.1', note: 'Ostermontag frei' },
  { n: 35, kw: 16, datum: '13.–17. Apr', month: 'April', trimester: 'T3', thema: 3, lessons: 3, type: 'teaching', title: 'T3.2 Nachhaltigkeit', lb: '3.2' },
  { n: 36, kw: 17, datum: '20.–24. Apr', month: 'April', trimester: 'T3', thema: null, lessons: 0, type: 'holiday', title: 'Frühjahrsferien' },
  { n: 37, kw: 18, datum: '27. Apr – 1. Mai', month: 'Mai', trimester: 'T3', thema: null, lessons: 0, type: 'holiday', title: 'Frühjahrsferien' },
  { n: 38, kw: 19, datum: '4.–8. Mai', month: 'Mai', trimester: 'T3', thema: 3, lessons: 3, type: 'teaching', title: 'T3.2 Konsumgewohnheiten', lb: '3.2' },
  { n: 39, kw: 20, datum: '11.–15. Mai', month: 'Mai', trimester: 'T3', thema: 3, lessons: 3, type: 'teaching', title: 'T3.2 Klimawandel & Ressourcen', lb: '3.2', note: 'Auffahrt + Brücke frei' },
  { n: 40, kw: 21, datum: '18.–22. Mai', month: 'Mai', trimester: 'T3', thema: 3, lessons: 3, type: 'teaching', title: 'T3.2 Produktwert', lb: '3.2' },
  { n: 41, kw: 22, datum: '25.–29. Mai', month: 'Mai', trimester: 'T3', thema: 3, lessons: 3, type: 'teaching', title: 'T3.2 Marktmechanismen', lb: '3.2', note: 'Pfingstmontag frei' },
  { n: 42, kw: 23, datum: '1.–5. Jun', month: 'Juni', trimester: 'T3', thema: 3, lessons: 3, type: 'teaching', title: 'T3.2 Anspruchsgruppen & Zielkonflikte', lb: '3.2' },
  { n: 43, kw: 24, datum: '8.–12. Jun', month: 'Juni', trimester: 'T3', thema: 3, lessons: 3, type: 'teaching', title: 'T3.3 Kaufverträge & Reklamation', lb: '3.3' },
  { n: 44, kw: 25, datum: '15.–19. Jun', month: 'Juni', trimester: 'T3', thema: 3, lessons: 3, type: 'buffer', title: 'T3 Puffer — Vertiefung' },
  { n: 45, kw: 26, datum: '22.–26. Jun', month: 'Juni', trimester: 'T3', thema: 3, lessons: 3, type: 'buffer', title: 'T3 Puffer — Abschluss' },
  { n: 46, kw: 27, datum: '29. Jun – 3. Jul', month: 'Juli', trimester: 'T3', thema: 3, lessons: 3, type: 'buffer', title: 'T3 Puffer & Portfolio-Review' },
  { n: 47, kw: 28, datum: '6.–10. Jul', month: 'Juli', trimester: 'T3', thema: 3, lessons: 3, type: 'buffer', title: 'T3 Abschluss & Jahresreflexion' },
]

const themas = [
  {
    nr: 1,
    titel: 'Ins Berufsleben einsteigen',
    lektionen: 24,
    puffer: 6,
    intensity: 'light',
    perioden: ['Aug–Sep: Lehrvertrag, Rechte/Pflichten, Kommunikation (T1.1)', 'Sep–Okt: Lernorganisation & Ressourcen (T1.2)', 'Okt: KN 1.1 Konfliktgespräch & Repetition', 'Nov: T1 Abschluss & Übergabe'],
  },
  {
    nr: 2,
    titel: 'Meinungen bilden und mitgestalten',
    lektionen: 33,
    puffer: 9,
    intensity: 'medium',
    perioden: ['Nov: Quellen & Desinformation (T2.1)', 'Dez–Jan: Diskriminierung & Meinungsfreiheit (T2.2)', 'Jan–Feb: Mitwirkung & Standpunkte (T2.3)', 'Feb–Mär: T2-Puffer (3 Wo.) & Abschluss'],
  },
  {
    nr: 3,
    titel: 'Bewusst konsumieren und handeln',
    lektionen: 33,
    puffer: 12,
    intensity: 'dark',
    perioden: ['Mär–Apr: Bedürfnisse & Budget (T3.1)', 'Apr–Jun: Nachhaltigkeit & Konsumkritik (T3.2)', 'Jun: T3.3 Kaufverträge & Reklamation (1 Wo.)', 'Jun–Jul: T3-Puffer (4 Wo.) & Jahresreflexion'],
  },
]

// Semester-Split: 1 = Aug–Jan (n ≤ 24), 2 = Feb–Jul (n ≥ 25)
const semesterOf = (n: number): 1 | 2 => (n <= 24 ? 1 : 2)
const calendarWithSem = calendar.map((c) => ({ ...c, semester: semesterOf(c.n) }))

const semesterSummary = ([1, 2] as const).map((s) => {
  const cells = calendarWithSem.filter((c) => c.semester === s)
  return {
    code: s,
    label: s === 1 ? 'Semester 1 · Aug – Jan' : 'Semester 2 · Feb – Jul',
    weeks: cells.filter((c) => c.type !== 'holiday').length,
    teaching: cells.filter((c) => c.type === 'teaching').reduce((sum, c) => sum + c.lessons, 0),
    buffer: cells.filter((c) => c.type === 'buffer').reduce((sum, c) => sum + c.lessons, 0),
    holidays: cells.filter((c) => c.type === 'holiday').length,
  }
})

// Pre-group months per semester for SSR rendering (no client-side tab switching)
type MonthGroup = { label: string; weeks: typeof calendarWithSem; lessons: number }
const semesterColumns = ([1, 2] as const).map((s) => {
  const cells = calendarWithSem.filter((c) => c.semester === s)
  const groups: MonthGroup[] = []
  let current: MonthGroup | null = null
  for (const w of cells) {
    const label = `${w.month} · ${w.trimester}`
    if (!current || current.label !== label) {
      current = { label, weeks: [], lessons: 0 }
      groups.push(current)
    }
    current.weeks.push(w)
    current.lessons += w.lessons
  }
  return { semester: s, groups }
})

// ── Feature 3: Feiertags-/Notizen-Panel ──────────────────────────────────
// `note` mixes real public-holiday/Brücken-hints with didactic markers.
// Split them so the panel reads cleanly when printed or shared.
const isFeiertag = (n: string) => /frei|brücke|bruecke|ferien/i.test(n)
const noteWeeks = calendar.filter((w) => w.note)
const feiertagNotes = noteWeeks.filter((w) => isFeiertag(w.note!))
const didaktikNotes = noteWeeks.filter((w) => !isFeiertag(w.note!))

// ── Phase 2 (Feature 4/6/8): load this user's saved plan instances (SSR) ──
// Table created by migration 011. Guarded so the page still renders if the
// migration has not been applied yet (data → null, error swallowed).
let plans: any[] = []
if (!isGuest) {
  try {
    const { data } = await Astro.locals.supabase
      .from('jahresplanung_plans')
      .select('*')
      .order('created_at', { ascending: true })
    plans = data ?? []
  } catch {
    plans = []
  }
}
---
<Base title="Jahresplanung 1. Lehrjahr">
  {isGuest && <GuestPrintBlock />}
  <div class="min-h-screen flex flex-col">
    <header class="bg-white border-b border-slate-200 sticky top-0 z-30">
      <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between gap-4">
        <a href="/" class="flex items-center gap-3 min-w-0">
          <img src="/logo-bbw-mark.png" alt="BBW Berufsbildungsschule Winterthur" class="logo-black h-14 w-auto shrink-0" />
          <span class="sr-only">BBW Berufsbildungsschule Winterthur</span>
          <span class="hidden md:block pl-3 ml-1 border-l border-slate-200 text-xs uppercase tracking-wider text-slate-500 leading-tight">
            Materialplattform<br />
            <span class="normal-case tracking-normal text-slate-400">ABU Reform 2030</span>
          </span>
        </a>
        <div class="flex items-center gap-4">
          <a href="/" class="text-sm text-slate-600 hover:text-slate-900 font-medium">← Hauptplattform</a>
          <span class="text-sm text-slate-500 hidden sm:block">{user.email}</span>
        </div>
      </div>
    </header>

    <main class="flex-1 max-w-7xl mx-auto w-full px-6 py-10" x-data="jahresplanung()" x-cloak>
      <!-- Title -->
      <div class="mb-6 flex flex-wrap items-start justify-between gap-4">
        <div>
          <p class="text-xs uppercase tracking-wider text-slate-500 mb-2">Jahresplanung · EFZ 3-Jährige · nRLP Bildungsrat 2026-01</p>
          <h1 class="text-3xl font-semibold text-slate-900 tracking-tight">ABU 1. Lehrjahr — Schuljahr 2025/2026</h1>
          <p class="text-slate-600 mt-3 max-w-3xl">
            39 Schulwochen · 3 Lektionen pro Woche · die drei Themen werden chronologisch
            nacheinander unterrichtet (T1 → T2 → T3). Fahre über eine Woche, um die geplanten
            Lebensbezüge und Kompetenzen aus dem nRLP einzusehen.
          </p>
        </div>
        <a
          href="/onboarding/guide-jahresplanung.html"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-4 py-2.5 rounded-lg font-semibold text-sm text-white shadow-sm transition-colors"
          style="background:var(--brand); white-space:nowrap;"
          onmouseover="this.style.background='var(--brand-dark)'"
          onmouseout="this.style.background='var(--brand)'"
        >
          <span style="font-size:1.1em">📖</span> Einführung &amp; Rundgang
        </a>
      </div>

      <!-- Gast-Hinweis (read-only) -->
      {isGuest && (
        <div class="mb-8 p-3 bg-amber-50 border border-amber-200 rounded-lg text-sm text-amber-800 flex items-center gap-2">
          <span class="text-xs font-medium px-2 py-0.5 rounded border border-amber-300 bg-amber-100 text-amber-700">Gast · nur Lesen</span>
          Jahresplanung in der Leseansicht — Bearbeiten, Klassen-Planung und Export sind angemeldeten Lehrpersonen vorbehalten.
        </div>
      )}

      <!-- Planungs-Toolbar (Feature 4/6/7/8) -->
      {!isGuest && (
      <div class="jp-toolbar bg-white border border-slate-200 rounded-lg p-3 mb-8 flex flex-wrap items-center gap-x-4 gap-y-3">
        <!-- Klassen-Instanzen -->
        <div class="flex items-center gap-2">
          <span class="text-xs font-semibold uppercase tracking-wider text-slate-500">Klasse</span>
          <template x-if="plans.length">
            <select x-model="activePlanId" x-on:change="switchPlan($event.target.value)" class="jp-select">
              <template x-for="p in plans" :key="p.id">
                <option :value="p.id" x-text="p.label"></option>
              </template>
            </select>
          </template>
          <template x-if="!plans.length">
            <span class="text-xs text-slate-400 italic">Basisvorlage (nicht gespeichert)</span>
          </template>
          <button class="jp-btn-ghost" x-on:click="newPlan()" :disabled="saving" title="Neue Klassen-Planung anlegen">＋ Klasse</button>
        </div>

        <span class="hidden sm:block w-px h-6 bg-slate-200"></span>

        <!-- Panel-Umschalter -->
