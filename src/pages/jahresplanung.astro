                  <p class="text-[10px] uppercase tracking-wider text-slate-400 mb-1">Kompetenzen (nRLP)</p>
                  <ul class="space-y-1.5 mb-3">
                    <template x-for="k in lookup[active.lb].kompetenzen" :key="k.nr">
                      <li class="text-xs leading-snug text-slate-700">
                        <span class="font-semibold text-[var(--brand-dark)]" x-text="k.nr"></span>
