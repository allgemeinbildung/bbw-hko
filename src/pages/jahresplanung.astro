                      <a :href="`/situationen?lebensbezug=${active.lb}`" target="_blank" rel="noopener" class="jp-sit-all" x-text="`Alle ${sitFor(active.lb).length} Situationen durchsuchen →`"></a>
                    </div>
                  </template>
