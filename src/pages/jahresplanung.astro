                    <p x-show="!recSm(lb).length" class="text-xs text-slate-400 italic">Keine Sprachmodi gelistet.</p>
                  </div>
                </div>
              </div>
            </template>
          </div>
        </div>
      </section>

      <!-- Timeline — two semesters side by side -->
      <section class="bg-white border border-slate-200 rounded-lg p-6 mb-8 relative">
        <h2 class="text-lg font-semibold text-slate-900 mb-5">Jahresübersicht (Schulwochen)</h2>

        <div class="grid lg:grid-cols-2 gap-x-8 gap-y-6">
          {semesterColumns.map((col, idx) => {
            const s = semesterSummary[idx]
            return (
              <div>
                <div class="flex items-baseline justify-between border-b border-slate-200 pb-2 mb-4">
                  <h3 class="text-sm font-semibold text-[var(--brand-dark)] uppercase tracking-wider">{s.label}</h3>
                  <span class="text-xs text-slate-500">{s.weeks} W · {s.teaching + s.buffer} L.</span>
                </div>
                {col.groups.map((group) => (
                  <div class="mb-5 last:mb-0">
                    <div class="flex items-baseline gap-3 mb-2">
                      <h4 class="text-sm font-semibold text-slate-700">{group.label}</h4>
                      <span class="text-xs text-slate-400">{group.weeks.length} W · {group.lessons} L.</span>
                    </div>
                    <div class="flex flex-wrap gap-2">
                      {group.weeks.map((w) => (
                        <button
                          x-on:mouseenter={`show(${w.n}, $event)`}
                          x-on:mouseleave="hide()"
                          x-on:focus={`show(${w.n}, $event)`}
                          x-on:blur="hide()"
                          x-on:click={`onCellClick(${w.n}, $event)`}
                          :class={`{
                            'cell-edit': editMode && mtype(${w.n}) !== 'holiday',
                            'cell-holiday': mtype(${w.n}) === 'holiday',
                            'cell-buffer': mtype(${w.n}) === 'buffer',
                            'cell-thema1': mtype(${w.n}) === 'thema1',
                            'cell-thema2': mtype(${w.n}) === 'thema2',
                            'cell-thema3': mtype(${w.n}) === 'thema3'
                          }`}
                          class={`lesson-cell ${
                            w.type === 'holiday' ? 'cell-holiday' :
                            w.type === 'buffer' ? 'cell-buffer' :
                            w.thema === 1 ? 'cell-thema1' :
                            w.thema === 2 ? 'cell-thema2' :
                            w.thema === 3 ? 'cell-thema3' : 'cell-buffer'
                          }`}
                        >
                          <span class="cell-star" x-show={`hasKn(${w.n})`} x-cloak>★</span>
                          <span class="cell-kw">KW {w.kw}</span>
                          <span class="cell-lessons" x-text={`mLessons(${w.n})`}>{w.lessons > 0 ? `${w.lessons} L.` : '–'}</span>
                          <span class="cell-title" x-text={`mTitleMark(${w.n})`}>{w.lb ? w.lb : (w.type === 'holiday' ? '★' : '·')}</span>
                          <span class="cell-hf" x-show={`hfCount(${w.n}) > 0`} x-cloak title="Herausforderungen (Einheiten)"><span class="cell-hf-dot">◆</span><span x-text={`hfCount(${w.n})`}></span></span>
                          <span class="cell-sit" x-show={`sitCount(${w.n}) > 0`} x-cloak x-text={`sitCount(${w.n})`} title="Situationen zur Inspiration"></span>
                        </button>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            )
          })}
        </div>

        <!-- Floating tooltip -->
        <div
          x-show="active"
          x-transition.opacity.duration.150ms
          :style="`top:${tipY}px; left:${tipX}px;`"
