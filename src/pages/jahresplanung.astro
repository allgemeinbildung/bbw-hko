                      </label>
                    </template>
                    <p x-show="!recSk(lb).length" class="text-xs text-slate-400 italic">Keine SK für dieses Thema gelistet.</p>
                  </div>
                  <div>
                    <p class="jp-cov-sub">Sprachmodi</p>
                    <template x-for="sm in recSm(lb)" :key="sm">
                      <label class="jp-check">
                        <input type="checkbox" :checked="isDone(lb,'sm',sm)" x-on:change="toggle(lb,'sm',sm)" />
