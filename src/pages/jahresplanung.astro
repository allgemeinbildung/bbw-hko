        <span class="flex items-center gap-2"><span class="legend-swatch cell-thema1"></span>Thema 1 — Einstieg</span>
        <span class="flex items-center gap-2"><span class="legend-swatch cell-thema2"></span>Thema 2 — Meinung</span>
        <span class="flex items-center gap-2"><span class="legend-swatch cell-thema3"></span>Thema 3 — Konsum</span>
        <span class="flex items-center gap-2"><span class="legend-swatch cell-buffer"></span>Puffer / Repetition</span>
        <span class="flex items-center gap-2"><span class="legend-swatch cell-holiday"></span>Ferien / Feiertag</span>
        <span class="flex items-center gap-2"><span class="legend-hf">◆</span>Herausforderung (Einheit)</span>
        <span class="flex items-center gap-2"><span class="legend-sit-mark">◇</span>Situationen (Inspiration)</span>
        <span class="ml-auto text-slate-500 italic">Tipp: Hover über eine Woche</span>
      </div>

      <!-- Themen detail -->
      <section class="mb-8">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">Themen im 1. Lehrjahr</h2>
        <div class="grid md:grid-cols-3 gap-4">
          {themas.map((t) => (
            <div class={`thema-card thema-card-${t.intensity}`}>
              <div class="thema-header">
                <span class="thema-nr">Thema {t.nr}</span>
                <h3 class="thema-titel">{t.titel}</h3>
              </div>
              <dl class="grid grid-cols-3 gap-2 mb-4">
                <div><dt class="thema-stat-label">Unterricht</dt><dd class="thema-stat-value">{t.lektionen} L.</dd></div>
                <div><dt class="thema-stat-label">Puffer</dt><dd class="thema-stat-value">{t.puffer} L.</dd></div>
                <div><dt class="thema-stat-label">Total</dt><dd class="thema-stat-value">{t.lektionen + t.puffer} L.</dd></div>
              </dl>
              <p class="thema-stat-label mb-1">Perioden</p>
              <ul class="space-y-1 text-xs text-slate-700">
                {t.perioden.map((p) => <li>· {p}</li>)}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <!-- Feature 1: SK-Abdeckungsmatrix (canonical nRLP) -->
      <section class="bg-white border border-slate-200 rounded-lg p-6 mb-8">
        <div class="flex items-baseline justify-between flex-wrap gap-2 mb-1">
          <h2 class="text-lg font-semibold text-slate-900">SK-Abdeckung im 1. Lehrjahr</h2>
          <span class="text-xs text-slate-400">Quelle: nRLP-Zirkularität · 12 Schlüsselkompetenzen</span>
        </div>
        <p class="text-sm text-slate-600 mb-4 max-w-3xl">
          Welche der 12 Schlüsselkompetenzen in T1–T3 eingeplant sind und in welcher
          Iterationstiefe (R1 = erste Begegnung, R2/R3 = Wiederaufnahme & Vertiefung).
          Graue Zeilen sind im 1. Lehrjahr <strong>nicht</strong> vorgesehen — vor einem
          Kompetenznachweis sichtbar machen, was geübt wurde.
        </p>
        <div class="sk-matrix">
          <div class="sk-row sk-head">
            <div class="sk-name">Schlüsselkompetenz</div>
            {SK_COLS.map((t) => <div class="sk-cell sk-colhead">{t}</div>)}
          </div>
          {skMatrix.map((sk) => (
            <div class={`sk-row ${sk.inYear ? '' : 'sk-row-off'}`}>
              <div class="sk-name" title={sk.full}>
                <span class="sk-nr">{sk.nr}</span>{sk.name}
              </div>
              {sk.cells.map((c) => (
                <div class={`sk-cell ${c ? `sk-r${c.replace('R', '')}` : 'sk-empty'}`}>
