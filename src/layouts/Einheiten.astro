---
import Base from './Base.astro'
import GuestPrintBlock from '../components/GuestPrintBlock.astro'

interface Props {
  title?: string
  role?: 'lp' | 'kt1' | 'gast'
  fullBleed?: boolean
}
const { title, role = 'lp', fullBleed = false } = Astro.props
const user = Astro.locals.user
const path = Astro.url.pathname

const success = Astro.url.searchParams.get('success')
const error = Astro.url.searchParams.get('error')
---
<Base title={title}>
  {role === 'gast' && <GuestPrintBlock />}
  <div class="min-h-screen flex flex-col">
    <header class="bg-white border-b border-slate-200 sticky top-0 z-30">
      <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between gap-4">
        <a href="/" class="flex items-center gap-3 min-w-0">
          <img src="/logo-bbw-mark.png" alt="BBW Berufsbildungsschule Winterthur" class="logo-black h-14 w-auto shrink-0" />
          <span class="min-w-0 pl-3 ml-1 border-l border-slate-200">
            <span class="block text-base font-semibold leading-tight truncate text-slate-900">Einheiten <span class="text-xs font-normal text-slate-500 ml-1 align-middle border border-slate-300 rounded px-1.5 py-0.5">Pilot</span></span>
            <span class="block text-xs text-slate-500 leading-tight truncate">ABU Reform 2030 · Vollunterricht inkl. KN</span>
          </span>
        </a>
        <nav class="flex gap-1 bg-slate-100 p-1 rounded-lg">
          <a href="/einheiten" class={`px-4 py-1.5 rounded-md text-sm font-medium transition ${path === '/einheiten' ? 'tab-active' : 'text-slate-600 hover:text-slate-900'}`}>Katalog Einheiten</a>
          {role === 'gast' && (
            <a href="/situationen" class={`px-4 py-1.5 rounded-md text-sm font-medium transition ${path.startsWith('/situationen') ? 'tab-active' : 'text-slate-600 hover:text-slate-900'}`}>Katalog Situationen</a>
          )}
          <a href={role === 'kt1' ? '/admin' : '/'} class="px-4 py-1.5 rounded-md text-sm font-medium text-slate-500 hover:text-slate-800">← Hauptplattform</a>
        </nav>
        <div class="flex items-center gap-3">
          {role === 'gast' && (
            <span class="text-xs font-medium px-2 py-0.5 rounded border border-amber-300 bg-amber-50 text-amber-700">Gast · nur Lesen</span>
          )}
          <a href="/onboarding/index.html" class="text-sm text-slate-400 hover:text-slate-600 hidden sm:block" title="Einführung &amp; Rundgang">Rundgang</a>
          <span class="text-sm text-slate-500 hidden sm:block">{role === 'gast' ? 'Gast' : user?.email}</span>
          <form method="POST" action="/api/auth/logout">
            <button type="submit" class="text-sm text-slate-500 hover:text-slate-700 underline">{role === 'gast' ? 'Verlassen' : 'Abmelden'}</button>
          </form>
        </div>
      </div>
    </header>

    {success && (
      <div class="bg-emerald-50 border-b border-emerald-200 px-6 py-2 text-sm text-emerald-700 text-center">{success}</div>
    )}
    {error && (
      <div class="bg-red-50 border-b border-red-200 px-6 py-2 text-sm text-red-700 text-center">{error}</div>
    )}

    {fullBleed
      ? <main class="flex-1 w-full"><slot /></main>
      : <main class="flex-1 max-w-7xl mx-auto w-full px-6 py-6"><slot /></main>
    }

    <footer class="border-t border-slate-200 py-4 px-6 text-center text-xs text-slate-400">
      Einheiten-Katalog · Pilot · ABU Reform 2030
    </footer>
  </div>
</Base>
