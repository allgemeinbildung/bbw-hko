---
import Base from './Base.astro'

interface Props {
  title?: string
}
const { title } = Astro.props
const user = Astro.locals.user
const path = Astro.url.pathname

const success = Astro.url.searchParams.get('success')
const error = Astro.url.searchParams.get('error')
---
<Base title={title}>
  <div class="min-h-screen flex flex-col">
    <header class="admin-header sticky top-0 z-20" style="background: var(--brand-dark); border-bottom: 1px solid rgba(255,255,255,0.08);">
      <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between gap-4">
        <a href="/admin" class="flex items-center gap-3 min-w-0">
          <img src="/logo-bbw-mark.png" alt="BBW Berufsbildungsschule Winterthur" class="h-14 w-auto shrink-0" style="filter: brightness(0) invert(1)" />
          <span class="hidden md:block pl-3 ml-1 border-l text-xs uppercase tracking-wider leading-tight" style="border-color: rgba(255,255,255,0.18); color: rgba(255,255,255,0.85);">
            ABU-Materialplattform<br />
            <span class="normal-case tracking-normal" style="color: rgba(255,255,255,0.55);">KT1 · Curator View</span>
          </span>
        </a>
        <nav class="flex gap-1 p-1 rounded-lg" style="background: rgba(0,0,0,0.18);">
          <a
            href="/admin"
            class={`px-4 py-1.5 rounded-md text-sm font-medium transition ${path === '/admin' ? 'admin-tab-active' : 'admin-tab'}`}
          >Übersicht</a>
          <a
            href="/admin/dashboard"
            class={`px-4 py-1.5 rounded-md text-sm font-medium transition ${path === '/admin/dashboard' ? 'admin-tab-active' : 'admin-tab'}`}
          >Lücken-Dashboard</a>
          <a
            href="/situationen/admin"
            class="px-4 py-1.5 rounded-md text-sm font-medium admin-tab"
          >Situationen-Feedbacks →</a>
          <a
            href="/einheiten"
            class="px-4 py-1.5 rounded-md text-sm font-medium admin-tab"
          >Einheiten →</a>
        </nav>
        <div class="flex items-center gap-3">
          <span class="text-sm hidden sm:block" style="color: rgba(255,255,255,0.7);">{user?.email}</span>
          <form method="POST" action="/api/auth/logout">
            <button type="submit" class="text-sm underline" style="color: rgba(255,255,255,0.7);">Abmelden</button>
          </form>
        </div>
      </div>
    </header>

    {success && (
      <div class="bg-emerald-50 border-b border-emerald-200 px-6 py-2 text-sm text-emerald-700 text-center">{success}</div>
    )}
    {error && (
      <div class="bg-red-50 border-b border-red-200 px-6 py-2 text-sm text-red-700 text-center">{error}</div>
    )}

    <main class="flex-1 max-w-7xl mx-auto w-full px-6 py-6">
      <slot />
    </main>

    <footer class="border-t border-slate-200 py-4 px-6 text-center text-xs text-slate-400">
      ABU-Materialplattform · KT1 Admin · ABU Reform 2030
    </footer>
  </div>

<style is:global>
  .admin-tab {
    color: rgba(255, 255, 255, 0.75);
  }
  .admin-tab:hover {
    color: white;
    background: rgba(255, 255, 255, 0.08);
  }
  .admin-tab-active {
    background: white;
    color: var(--brand-dark);
  }
</style>
</Base>
