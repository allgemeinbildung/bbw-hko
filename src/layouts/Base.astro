---
import ViewAsBanner from '../components/ViewAsBanner.astro'
interface Props {
  title?: string
}
const { title = 'Materialplattform' } = Astro.props
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Materialplattform</title>
  <link rel="icon" type="image/svg+xml" href="/lion-only.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300..700&display=swap" rel="stylesheet" />
  <script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/collapse@3.14.1/dist/cdn.min.js"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.1/dist/cdn.min.js"></script>
  <style is:global>
    :root {
      --brand: #0E6E3A;
      --brand-dark: #094d28;
      --brand-tint: #e8f3ec;
      --brand-ring: rgba(14, 110, 58, 0.18);

      /* ── nRLP Thema-Identitätsfarben (Bildungsrat 2026) ──────────────────
         Quelle: SLP-PDFs EFZ 3-/4-jährig (Pascal Rusch, 10.06.2026).
         Einzige bewusste Ausnahme zur "Single-Green"-Regel.
         Doku: docs/thema-farben.md · Helper: src/lib/thema-colors.ts
         --thema-N-ink = WCAG-AA-konforme Textfarbe auf der Thema-Fläche. */
      --thema-1: #009EE0; --thema-1-ink: #000000;
      --thema-2: #EC008C; --thema-2-ink: #000000;
      --thema-3: #EB690B; --thema-3-ink: #000000;
      --thema-4: #3EA743; --thema-4-ink: #000000;
      --thema-5: #033E80; --thema-5-ink: #FFFFFF;
      --thema-6: #885EA0; --thema-6-ink: #FFFFFF;
      --thema-7: #007B7A; --thema-7-ink: #FFFFFF;
      --thema-8: #00A1A3; --thema-8-ink: #000000;
    }

    /* data-thema="N" setzt die lokalen Custom-Properties --tc / --tc-ink,
       die die Thema-Utility-Klassen unten konsumieren. Fallback = Brand-Grün. */
    [data-thema="1"] { --tc: var(--thema-1); --tc-ink: var(--thema-1-ink); }
    [data-thema="2"] { --tc: var(--thema-2); --tc-ink: var(--thema-2-ink); }
    [data-thema="3"] { --tc: var(--thema-3); --tc-ink: var(--thema-3-ink); }
    [data-thema="4"] { --tc: var(--thema-4); --tc-ink: var(--thema-4-ink); }
    [data-thema="5"] { --tc: var(--thema-5); --tc-ink: var(--thema-5-ink); }
    [data-thema="6"] { --tc: var(--thema-6); --tc-ink: var(--thema-6-ink); }
    [data-thema="7"] { --tc: var(--thema-7); --tc-ink: var(--thema-7-ink); }
    [data-thema="8"] { --tc: var(--thema-8); --tc-ink: var(--thema-8-ink); }
    /* EBA 2-jährig: gleiche Palette, andere Zuordnung (T2–T6). Greift nur unter
       einem data-lehrgang="EBA"-Vorfahren oder direkt am selben Element. */
    [data-lehrgang="EBA"][data-thema="2"], [data-lehrgang="EBA"] [data-thema="2"] { --tc: var(--thema-3); --tc-ink: var(--thema-3-ink); }
    [data-lehrgang="EBA"][data-thema="3"], [data-lehrgang="EBA"] [data-thema="3"] { --tc: var(--thema-4); --tc-ink: var(--thema-4-ink); }
    [data-lehrgang="EBA"][data-thema="4"], [data-lehrgang="EBA"] [data-thema="4"] { --tc: var(--thema-6); --tc-ink: var(--thema-6-ink); }
    [data-lehrgang="EBA"][data-thema="5"], [data-lehrgang="EBA"] [data-thema="5"] { --tc: var(--thema-2); --tc-ink: var(--thema-2-ink); }
    [data-lehrgang="EBA"][data-thema="6"], [data-lehrgang="EBA"] [data-thema="6"] { --tc: var(--thema-5); --tc-ink: var(--thema-5-ink); }
    .thema-fill { background: var(--tc, var(--brand)); color: var(--tc-ink, #fff); border-color: transparent; }
    .thema-top { border-top-color: var(--tc, var(--brand)) !important; }
    .thema-left { border-left-color: var(--tc, var(--brand)) !important; }
    .thema-ink { color: var(--tc, var(--brand-dark)); }
    .thema-dot { background: var(--tc, var(--brand)); }
    .thema-chip { display: inline-flex; align-items: center; padding: 0.125rem 0.5rem; font-size: 0.7rem; line-height: 1.4; font-weight: 600; border-radius: 9999px; background: var(--tc, var(--brand)); color: var(--tc-ink, #fff); }
    .thema-soft { background: color-mix(in srgb, var(--tc, var(--brand)) 14%, #fff); color: var(--tc, var(--brand-dark)); }
    html, body { font-family: 'DM Sans', system-ui, sans-serif; background: #f8fafc; color: #0f172a; }
    [x-cloak] { display: none !important; }
    .tab-active { background: var(--brand); color: white; }
    .chip { display: inline-flex; align-items: center; padding: 0.125rem 0.5rem; font-size: 0.7rem; border-radius: 9999px; background: #e2e8f0; color: #1e293b; line-height: 1.4; }
    .chip-blue { background: var(--brand-tint); color: var(--brand-dark); }
    .chip-green { background: #dcfce7; color: #166534; }
    .field-label { font-size: 0.75rem; font-weight: 600; color: #475569; text-transform: uppercase; letter-spacing: 0.04em; }
    .input { width: 100%; border: 1px solid #cbd5e1; border-radius: 0.375rem; padding: 0.5rem 0.625rem; font-size: 0.875rem; background: white; transition: border-color 0.12s, box-shadow 0.12s; }
    .input:focus { outline: none; border-color: var(--brand); box-shadow: 0 0 0 3px var(--brand-ring); }
    .input.invalid { border-color: #dc2626; box-shadow: 0 0 0 3px rgba(220,38,38,0.12); }
    .radio-group { display: flex; gap: 0.5rem; flex-wrap: wrap; }
    .radio-pill { cursor: pointer; padding: 0.4rem 0.75rem; border: 1px solid #cbd5e1; border-radius: 9999px; font-size: 0.8rem; background: white; user-select: none; transition: all 0.12s; }
    .radio-pill:hover { background: #f1f5f9; }
    .radio-pill.selected { background: var(--brand); color: white; border-color: var(--brand); }
    .check-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.4rem 0.75rem; }
    .check-item { display: flex; align-items: flex-start; gap: 0.5rem; padding: 0.4rem 0.5rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; cursor: pointer; font-size: 0.8rem; background: white; transition: background 0.1s; }
    .check-item:hover { background: #f1f5f9; }
    .check-item input { margin-top: 0.15rem; flex-shrink: 0; accent-color: var(--brand); }
    .check-item.checked { background: var(--brand-tint); border-color: #86c89b; }
    .toggle { position: relative; width: 36px; height: 20px; background: #cbd5e1; border-radius: 9999px; cursor: pointer; transition: background 0.15s; flex-shrink: 0; }
    .toggle.on { background: var(--brand); }
    .toggle::after { content: ''; position: absolute; top: 2px; left: 2px; width: 16px; height: 16px; background: white; border-radius: 9999px; transition: transform 0.15s; }
    .toggle.on::after { transform: translateX(16px); }
    .logo-black { filter: brightness(0) saturate(100%); image-rendering: -webkit-optimize-contrast; }
    .lion-bg { position: relative; overflow: hidden; }
    .lion-bg::before {
      content: '';
      position: absolute;
      right: -24px;
      top: -16px;
      width: 200px;
      height: 220px;
      background-image: url('/lion-only.svg');
      background-repeat: no-repeat;
      background-position: right center;
      background-size: contain;
      opacity: 0.05;
      pointer-events: none;
      z-index: 0;
    }
    .lion-bg > * { position: relative; z-index: 1; }
    .bar-track { width: 100%; height: 8px; background: #e2e8f0; border-radius: 9999px; overflow: hidden; }
    .bar-fill { height: 100%; transition: width 0.3s; }
    .bar-red { background: #ef4444; }
    .bar-yellow { background: #f59e0b; }
    .bar-green { background: #22c55e; }
  </style>
</head>
<body class="min-h-screen">
  <ViewAsBanner />
  <slot />
</body>
</html>
